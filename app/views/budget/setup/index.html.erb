<% content_for :title, "Budget Set up" %>
<div class="admin-layout-main budget-page bg-stone-50 min-vh-100">
  <%= render "components/odt/page_header", title: "Budget Set up", subtitle: "Years, categories, allocations, rules", icon: "gear" do %>
    <%= link_to "Create budget year", new_budget_year_path, class: "odt-btn odt-btn--primary odt-btn--sm" %>
  <% end %>

  <div class="row g-3">
    <div class="col-md-6">
      <div class="insight-card bg-white border border-stone-200 rounded-2xl shadow-sm h-100">
        <div class="insight-card__header">
          <div class="insight-card__accent"></div>
          <div class="insight-card__head-text">
            <h2 class="insight-card__title text-lg font-semibold text-stone-800">Budget years</h2>
            <p class="insight-card__subtitle">Create and manage years; copy from previous</p>
          </div>
        </div>
        <div class="insight-card__body">
          <% if @budget_years.any? %>
            <ul class="list-unstyled mb-0">
              <% @budget_years.each do |by| %>
                <li class="d-flex justify-content-between align-items-center py-2 border-bottom border-stone-200">
                  <%= link_to "Budget #{by.year}", budget_setup_path(year_id: by.id), class: "text-decoration-none text-stone-800 #{'fw-bold' if @selected_year&.id == by.id}" %>
                  <span class="badge <%= by.status == 'active' ? 'bg-emerald-600' : by.status == 'closed' ? 'bg-stone-400' : 'bg-amber-500' %>"><%= by.status %></span>
                </li>
              <% end %>
            </ul>
            <div class="mt-3">
              <%= link_to "All years", budget_years_path, class: "odt-btn odt-btn--ghost odt-btn--sm" %>
            </div>
          <% else %>
            <p class="text-muted mb-2">No budget years yet.</p>
            <%= link_to "Create budget year", new_budget_year_path, class: "odt-btn odt-btn--primary odt-btn--sm" %>
          <% end %>
        </div>
      </div>
    </div>

    <div class="col-md-6">
      <div class="insight-card bg-white border border-stone-200 rounded-2xl shadow-sm h-100">
        <div class="insight-card__header">
          <div class="insight-card__accent"></div>
          <div class="insight-card__head-text">
            <h2 class="insight-card__title text-lg font-semibold text-stone-800">Categories</h2>
            <p class="insight-card__subtitle">Expense categories for allocations</p>
          </div>
        </div>
        <div class="insight-card__body">
          <% if @budget_categories.any? %>
            <div class="odt-table-wrap">
              <table class="odt-table odt-table--sm">
                <thead><tr><th>Name</th><th>Code</th><th>Cost type</th></tr></thead>
                <tbody>
                  <% @budget_categories.each do |c| %>
                    <tr><td><%= c.name %></td><td><%= c.code %></td><td><%= c.cost_type %></td></tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          <% else %>
            <p class="text-muted mb-0">No categories. Run seeds or add via console.</p>
          <% end %>
        </div>
      </div>
    </div>

    <% if @selected_year %>
      <div class="col-12">
        <div class="insight-card bg-white border border-stone-200 rounded-2xl shadow-sm">
          <div class="insight-card__header">
            <div class="insight-card__accent"></div>
            <div class="insight-card__head-text">
              <h2 class="insight-card__title text-lg font-semibold text-stone-800">Allocations · <%= @selected_year.year %></h2>
              <p class="insight-card__subtitle">Allocated amount per category; optional monthly plan</p>
            </div>
            <div class="ms-auto">
              <%= link_to "Full allocations page", allocations_budget_year_path(@selected_year), class: "odt-btn odt-btn--ghost odt-btn--sm" %>
            </div>
          </div>
          <div class="insight-card__body">
            <%= render "budget/setup/allocations_table", allocations: @allocations, budget_year: @selected_year, budget_categories: @budget_categories %>
          </div>
        </div>
      </div>

      <div class="col-12">
        <div class="insight-card bg-white border border-stone-200 rounded-2xl shadow-sm">
          <div class="insight-card__header">
            <div class="insight-card__accent"></div>
            <div class="insight-card__head-text">
              <h2 class="insight-card__title text-lg font-semibold text-stone-800">Rules</h2>
              <p class="insight-card__subtitle">Alert thresholds and definitions</p>
            </div>
          </div>
          <div class="insight-card__body">
            <ul class="list-unstyled mb-0 small text-stone-600">
              <li><strong>Alert thresholds:</strong> 70% (warning), 80% (high), 100% (over budget)</li>
              <li><strong>Planned:</strong> Not yet committed or paid</li>
              <li><strong>Committed:</strong> Approved or obligated</li>
              <li><strong>Paid:</strong> Payment completed</li>
              <li>Changes are logged with timestamps; audit-friendly.</li>
            </ul>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
