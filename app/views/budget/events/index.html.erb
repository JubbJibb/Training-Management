<% content_for :title, "Events & sponsorship" %>
<div class="admin-layout-main budget-page">
  <%= render "components/odt/page_header", title: "Events & sponsorship", subtitle: "Events and sponsorship deals", icon: "calendar-event" do %>
    <%= link_to "New event", new_budget_event_path, class: "odt-btn odt-btn--primary odt-btn--sm" %>
  <% end %>

  <div class="insight-card">
    <div class="insight-card__body">
      <% if @events.any? %>
        <div class="odt-table-wrap">
          <table class="odt-table insight-odt-table" role="table">
            <thead>
              <tr>
                <th scope="col">Name</th>
                <th scope="col">Dates</th>
                <th scope="col">Organizer</th>
                <th scope="col">Location</th>
                <th scope="col">Objective</th>
                <th scope="col" class="text-end">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% @events.each do |ev| %>
                <tr>
                  <td><%= link_to ev.name, budget_event_path(ev), class: "odt-link" %></td>
                  <td><%= ev.start_date&.strftime("%d %b") %> – <%= ev.end_date&.strftime("%d %b %Y") %></td>
                  <td><%= ev.organizer.presence || "—" %></td>
                  <td><%= ev.location.presence || "—" %></td>
                  <td><%= ev.objective.presence || "—" %></td>
                  <td class="text-end">
                    <%= link_to "View", budget_event_path(ev), class: "odt-btn odt-btn--ghost odt-btn--sm" %>
                    <%= link_to "Edit", edit_budget_event_path(ev), class: "odt-btn odt-btn--ghost odt-btn--sm" %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <p class="text-muted mb-0">No events yet. <%= link_to "Create one", new_budget_event_path %>.</p>
      <% end %>
    </div>
  </div>
</div>
