<% content_for :title, "Edit expense" %>
<div class="admin-layout-main budget-page">
  <%= render "components/odt/page_header", title: "Edit expense", subtitle: "Budget #{@expense.budget_year.year}", icon: "wallet2" do %>
    <%= link_to "Back to register", expenses_budget_year_path(@expense.budget_year), class: "odt-btn odt-btn--ghost odt-btn--sm" %>
  <% end %>

  <div class="insight-card" style="max-width: 560px;">
    <div class="insight-card__body">
      <%= form_with model: @expense, url: budget_expense_path(@expense), method: :patch, local: true do |f| %>
        <div class="mb-3">
          <%= f.label :budget_category_id, "Category", class: "form-label" %>
          <%= f.collection_select :budget_category_id, @budget_categories, :id, :name, {}, class: "form-select", required: true %>
        </div>
        <div class="mb-3">
          <%= f.label :amount, "Amount", class: "form-label" %>
          <%= f.number_field :amount, step: 0.01, min: 0.01, class: "form-control", required: true %>
        </div>
        <div class="mb-3">
          <%= f.label :expense_date, "Date", class: "form-label" %>
          <%= f.date_field :expense_date, class: "form-control", required: true %>
        </div>
        <div class="mb-3">
          <%= f.label :vendor, "Vendor / Payee", class: "form-label" %>
          <%= f.text_field :vendor, class: "form-control" %>
        </div>
        <div class="mb-3">
          <%= f.label :reference_no, "Reference no.", class: "form-label" %>
          <%= f.text_field :reference_no, class: "form-control" %>
        </div>
        <div class="mb-3">
          <%= f.label :payment_status, "Status", class: "form-label" %>
          <%= f.select :payment_status, Budget::Expense::PAYMENT_STATUSES, {}, class: "form-select" %>
        </div>
        <div class="mb-3">
          <%= f.label :payment_method, "Payment method", class: "form-label" %>
          <%= f.text_field :payment_method, class: "form-control" %>
        </div>
        <div class="mb-3">
          <%= f.label :notes, "Notes", class: "form-label" %>
          <%= f.text_area :notes, class: "form-control", rows: 2 %>
        </div>
        <div class="d-flex gap-2">
          <%= f.submit "Update", class: "odt-btn odt-btn--primary" %>
          <%= link_to "Cancel", expenses_budget_year_path(@expense.budget_year), class: "odt-btn odt-btn--ghost" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
