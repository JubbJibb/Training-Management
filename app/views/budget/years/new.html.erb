<% content_for :title, "New budget year" %>
<div class="admin-layout-main budget-page">
  <%= render "components/odt/page_header", title: "New budget year", subtitle: "Create a yearly budget", icon: "wallet2" %>

  <div class="insight-card" style="max-width: 480px;">
    <div class="insight-card__body">
      <%= form_with model: @budget_year, url: budget_years_path, method: :post, local: true do |f| %>
        <div class="mb-3">
          <%= f.label :year, "Year", class: "form-label" %>
          <%= f.number_field :year, class: "form-control", min: Date.current.year - 5, max: Date.current.year + 5, required: true %>
        </div>
        <div class="mb-3">
          <%= f.label :total_budget, "Total budget", class: "form-label" %>
          <%= f.number_field :total_budget, class: "form-control", step: 0.01, min: 0, value: @budget_year.total_budget %>
        </div>
        <div class="mb-3">
          <%= f.label :status, "Status", class: "form-label" %>
          <%= f.select :status, Budget::Year::STATUSES, {}, class: "form-select" %>
        </div>
        <div class="mb-3">
          <%= f.label :owner_name, "Owner", class: "form-label" %>
          <%= f.text_field :owner_name, class: "form-control" %>
        </div>
        <div class="mb-3">
          <%= f.label :notes, "Notes", class: "form-label" %>
          <%= f.text_area :notes, class: "form-control", rows: 2 %>
        </div>
        <div class="d-flex gap-2">
          <%= f.submit "Create", class: "odt-btn odt-btn--primary" %>
          <%= link_to "Cancel", budget_years_path, class: "odt-btn odt-btn--ghost" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
