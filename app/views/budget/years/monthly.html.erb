<% content_for :title, "Monthly · Budget #{@budget_year.year}" %>
<div class="admin-layout-main budget-page">
  <%= render "components/odt/page_header", title: "Monthly summary · #{@budget_year.year}", subtitle: "Drilldown by month", icon: "wallet2" do %>
    <%= link_to "Back to overview", budget_year_path(@budget_year), class: "odt-btn odt-btn--ghost odt-btn--sm" %>
  <% end %>

  <div class="budget-monthly-selectors" style="margin-bottom: var(--odt-spacing);" data-controller="budget-month-switch">
    <%= form_with url: monthly_budget_year_path(@budget_year), method: :get, data: { turbo_frame: "budget_monthly_content" }, html: { class: "d-flex gap-2 align-items-end flex-wrap" } do |f| %>
      <div>
        <label for="budget_month" class="form-label small">Month</label>
        <select name="month" id="budget_month" class="form-select form-select-sm" style="width: auto;" data-action="change->budget-month-switch#submit">
          <% (1..12).each do |m| %>
            <option value="<%= m %>" <%= "selected" if @month == m %>><%= Date::MONTHNAMES[m] %></option>
          <% end %>
        </select>
      </div>
      <div>
        <span class="text-muted small"><%= @budget_year.year %></span>
      </div>
      <button type="submit" class="odt-btn odt-btn--primary odt-btn--sm">Go</button>
    <% end %>
  </div>

  <%= turbo_frame_tag "budget_monthly_content" do %>
    <%= render "budget/years/monthly_kpis", summary_month: @summary_month %>
    <%= render "budget/years/monthly_by_category", by_category_month: @by_category_month %>
    <%= render "budget/years/monthly_expenses_list", expenses_month: @expenses_month, budget_year: @budget_year %>
    <div class="mt-3">
      <button type="button" class="odt-btn odt-btn--ghost odt-btn--sm" disabled title="Export (placeholder)">Export</button>
    </div>
  <% end %>
</div>
