<%
  staff_profile = local_assigns[:staff_profile]
  form_id = local_assigns[:form_id] || "staff_profile_form"
%>
<header class="customer-edit-header" aria-label="Staff profile header">
  <div class="customer-edit-header__main">
    <div class="customer-edit-header__info">
      <h1 class="customer-edit-header__title"><%= staff_profile.persisted? ? "Edit staff profile" : "Add staff profile" %></h1>
      <p class="customer-edit-header__sub"><%= staff_profile.persisted? ? staff_profile.name : "Name, role, department, rate" %></p>
      <% if staff_profile.persisted? && staff_profile.updated_at.present? %>
        <p class="customer-edit-header__meta">Last updated: <%= staff_profile.updated_at.strftime("%d %b %Y %H:%M") %></p>
      <% end %>
    </div>
    <div class="customer-edit-header__actions">
      <%= link_to budget_staff_path, class: "odt-btn odt-btn--ghost odt-btn--sm" do %>
        <i class="bi bi-arrow-left odt-btn__icon" aria-hidden="true"></i><span class="odt-btn__label">Back</span>
      <% end %>
      <button type="submit" form="<%= form_id %>" class="odt-btn odt-btn--primary odt-btn--sm">
        <i class="bi bi-check-lg odt-btn__icon" aria-hidden="true"></i><span class="odt-btn__label"><%= staff_profile.persisted? ? "Save" : "Create" %></span>
      </button>
    </div>
  </div>
</header>
