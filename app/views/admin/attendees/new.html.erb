<% content_for :title, "Add Attendee" %>

<div class="attendee-edit-page attendee-edit-page--m3 attendee-edit-page--new">
  <%# Header: Add mode only (no view/edit toggle) %>
  <div class="attendee-edit-header">
    <div class="attendee-edit-header__main">
      <div>
        <h1 class="attendee-edit-header__title"><i class="bi bi-person-plus" aria-hidden="true"></i> Add Attendee</h1>
        <p class="attendee-edit-header__subtitle text-muted mb-0 small"><%= @training_class.title %></p>
      </div>
      <div class="attendee-edit-header__actions">
        <%= link_to (params[:return_to].presence || admin_class_workspace_attendees_path(@training_class)), class: "odt-btn odt-btn--secondary odt-btn--sm" do %>
          <i class="bi bi-arrow-left" aria-hidden="true"></i> Back to Attendees
        <% end %>
        <button type="submit" form="attendee-new-form" class="odt-btn odt-btn--primary odt-btn--sm">
          <i class="bi bi-check-lg" aria-hidden="true"></i> Add Attendee
        </button>
      </div>
    </div>
  </div>

  <%= form_with model: [:admin, @training_class, @attendee], local: true, multipart: true, class: "attendee-edit-form", id: "attendee-new-form" do |f| %>
    <%= hidden_field_tag :return_to, params[:return_to] if params[:return_to].present? %>
    <%= f.hidden_field :customer_id, value: @attendee.customer_id, id: "attendee_customer_id" %>

    <%# เลือกจากลูกค้าที่มีอยู่ แล้วเติมข้อมูลให้อัตโนมัติ %>
    <div class="card mb-4 border-primary">
      <div class="card-body py-3">
        <label class="form-label small mb-1 fw-semibold"><i class="bi bi-person-lines-fill" aria-hidden="true"></i> เลือกจากลูกค้าที่มีอยู่</label>
        <div class="d-flex flex-wrap align-items-center gap-2">
          <select id="select-customer-prefill" class="form-select form-select-sm" style="max-width: 360px;" aria-label="เลือกลูกค้า">
            <option value="">— เลือกลูกค้า (เติมข้อมูลให้อัตโนมัติ) —</option>
            <% (@customers_for_select || []).each do |id, name, email| %>
              <option value="<%= id %>" <%= 'selected' if @attendee.customer_id.to_i == id %>><%= "#{name} (#{email})" %></option>
            <% end %>
          </select>
          <button type="button" class="odt-btn odt-btn--secondary odt-btn--sm" id="btn-clear-customer-prefill" style="<%= 'display: none;' unless @attendee.customer_id.present? %>">
            <i class="bi bi-x-circle" aria-hidden="true"></i> ล้างการเลือก
          </button>
        </div>
      </div>
    </div>

    <% if @attendee.errors.any? %>
      <div class="alert alert-danger mb-4" role="alert">
        <h5>Please fix the following errors:</h5>
        <ul class="mb-0">
          <% @attendee.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <nav class="attendee-edit-tabs" aria-label="Attendee sections">
      <div class="attendee-edit-tabs__inner" role="tablist">
        <button class="attendee-edit-tabs__tab active" type="button" data-bs-toggle="tab" data-bs-target="#tab-details-new">
          <i class="bi bi-person-vcard"></i> Details
        </button>
        <button class="attendee-edit-tabs__tab" type="button" data-bs-toggle="tab" data-bs-target="#tab-summary-new">
          <i class="bi bi-receipt"></i> Payment Summary
        </button>
      </div>
    </nav>

    <div class="tab-content attendee-edit-tab-content" id="attendeeNewTabsContent">
      <div class="tab-pane fade show active" id="tab-details-new" role="tabpanel">
        <div class="attendee-edit-content attendee-edit-content--m3">
          <div class="attendee-edit-content__main">
            <%= render "admin/attendees/edit_sections/profile", f: f %>
            <%= render "admin/attendees/edit_sections/registration", f: f %>
            <%= render "admin/attendees/edit_sections/tax_info", f: f %>
          </div>
          <div class="attendee-edit-content__side">
            <%= render "admin/attendees/edit_sections/pricing", f: f %>
            <div class="attendee-edit-surface mt-3" id="attendee-new-price-summary">
              <div class="attendee-edit-surface__header">
                <i class="bi bi-calculator" aria-hidden="true"></i>
                <span>สรุปราคา</span>
              </div>
              <div class="attendee-edit-surface__body">
                <input type="hidden" id="base_price_input" value="<%= @training_class.price.to_f || 0 %>" readonly>
                <div class="d-flex justify-content-between mb-2"><span>ราคาเริ่มต้น:</span><span class="text-end"><strong id="display_base_price">0.00</strong> ฿</span></div>
                <div class="mb-2">
                  <div class="d-flex justify-content-between mb-1 text-success"><span>ส่วนลดรวม:</span><span class="text-end"><strong id="display_discount">0.00</strong> ฿</span></div>
                  <div id="discount_details" class="ms-2 small text-muted text-start"></div>
                </div>
                <div class="d-flex justify-content-between mb-2"><span>ราคาก่อน VAT:</span><span class="text-end"><strong id="display_price_before_vat">0.00</strong> ฿</span></div>
                <div class="d-flex justify-content-between mb-2 text-info"><span>VAT (7%):</span><span class="text-end"><strong id="display_vat">0.00</strong> ฿</span></div>
                <hr class="my-2">
                <div class="d-flex justify-content-between"><strong>ราคาสุทธิ (รวม VAT):</strong><span class="text-end"><strong class="text-primary" id="display_final_price">0.00</strong> ฿</span></div>
              </div>
            </div>
            <%= render "admin/attendees/edit_sections/documents", f: f %>
          </div>
        </div>
      </div>

      <div class="tab-pane fade" id="tab-summary-new" role="tabpanel">
        <div class="attendee-summary-view">
          <div class="odt-card p-4">
            <p class="text-muted mb-0">
              <i class="bi bi-info-circle" aria-hidden="true"></i>
              Save the attendee first to see the payment summary.
            </p>
          </div>
        </div>
      </div>
    </div>
  <% end %>
</div>

<%= content_for :footer_scripts do %>
<script>
document.addEventListener('DOMContentLoaded', function() {
  var selectCustomer = document.getElementById('select-customer-prefill');
  var hiddenCustomerId = document.getElementById('attendee_customer_id');
  var btnClearCustomer = document.getElementById('btn-clear-customer-prefill');
  var attendeeInfoBasePath = '<%= admin_customers_path %>';

  function setField(name, value) {
    var el = document.querySelector('[name="attendee[' + name + ']"]');
    if (el) {
      if (el.type === 'checkbox') el.checked = !!value;
      else el.value = value == null ? '' : value;
    }
  }

  function prefillFromCustomer(data) {
    setField('name', data.name);
    setField('email', data.email);
    setField('phone', data.phone);
    setField('participant_type', data.participant_type);
    setField('company', data.company);
    setField('tax_id', data.tax_id);
    setField('name_thai', data.name_thai);
    setField('billing_name', data.billing_name);
    setField('address', data.address);
    setField('billing_address', data.billing_address);
    if (hiddenCustomerId) hiddenCustomerId.value = data.id || '';
    if (btnClearCustomer) btnClearCustomer.style.display = '';
    var seatsIndiHint = document.getElementById('seats-indi-hint');
    if (data.participant_type === 'Corp') {
      if (seatsIndiHint) seatsIndiHint.style.display = 'none';
    } else {
      if (seatsIndiHint) seatsIndiHint.style.display = 'block';
    }
    var participantSelect = document.getElementById('participant_type_select');
    if (participantSelect) participantSelect.dispatchEvent(new Event('change', { bubbles: true }));
    if (typeof calculatePrice === 'function') calculatePrice();
  }

  if (selectCustomer) {
    selectCustomer.addEventListener('change', function() {
      var id = this.value;
      if (!id) {
        if (hiddenCustomerId) hiddenCustomerId.value = '';
        if (btnClearCustomer) btnClearCustomer.style.display = 'none';
        return;
      }
      var url = attendeeInfoBasePath + '/' + id + '/attendee_info.json';
      fetch(url, { headers: { 'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest' } })
        .then(function(r) { return r.json(); })
        .then(prefillFromCustomer)
        .catch(function() {});
    });
  }
  if (btnClearCustomer) {
    btnClearCustomer.addEventListener('click', function() {
      if (selectCustomer) selectCustomer.value = '';
      if (hiddenCustomerId) hiddenCustomerId.value = '';
      btnClearCustomer.style.display = 'none';
    });
  }

  var participantTypeSelect = document.getElementById('participant_type_select');
  var seatsField = document.getElementById('seats-field');
  var seatsIndiHint = document.getElementById('seats-indi-hint');
  var seatsInput = document.querySelector('input[name="attendee[seats]"]');
  var basePriceInput = document.querySelector('input[id="base_price_input"]');
  var promotionCheckboxes = document.querySelectorAll('.promotion-checkbox');

  if (participantTypeSelect) {
    participantTypeSelect.addEventListener('change', function() {
      if (this.value === 'Corp') {
        if (seatsField) seatsField.style.display = 'block';
        if (seatsIndiHint) seatsIndiHint.style.display = 'none';
        if (seatsInput) { seatsInput.value = seatsInput.value || '1'; seatsInput.removeAttribute('readonly'); }
      } else {
        if (seatsField) seatsField.style.display = 'none';
        if (seatsIndiHint) seatsIndiHint.style.display = 'block';
        if (seatsInput) { seatsInput.value = '1'; seatsInput.setAttribute('readonly', 'readonly'); }
      }
    });
  }

  function calculatePrice() {
    if (!basePriceInput) return;
    var basePricePerSeat = parseFloat(basePriceInput.value) || <%= @training_class.price.to_f || 0 %>;
    var seats = 1;
    if (seatsInput && seatsInput.value) seats = Math.max(1, parseInt(seatsInput.value, 10) || 1);
    var totalDiscountPerSeat = 0;
    var discountDetails = [];
    if (promotionCheckboxes && promotionCheckboxes.length) {
      promotionCheckboxes.forEach(function(checkbox) {
        if (checkbox.checked) {
          var discountType = checkbox.dataset.discountType;
          var discountValue = parseFloat(checkbox.dataset.discountValue) || 0;
          var promotionName = checkbox.dataset.promotionName || '';
          var discount = 0;
          var discountDesc = '';
          if (discountType === 'percentage') {
            discount = parseFloat((basePricePerSeat * (discountValue / 100)).toFixed(2));
            discountDesc = promotionName + ' (' + discountValue + '%)';
          } else if (discountType === 'fixed') {
            discount = parseFloat(discountValue.toFixed(2));
            discountDesc = promotionName + ' (' + discountValue.toFixed(2) + ' บาท)';
          } else if (discountType === 'buy_x_get_y') {
            discount = parseFloat((basePricePerSeat / (discountValue + 1)).toFixed(2));
            discountDesc = promotionName + ' (มา ' + (discountValue + 1) + ' จ่าย ' + discountValue + ')';
          }
          if (discount > 0) {
            totalDiscountPerSeat += discount;
            discountDetails.push({ name: discountDesc, amount: discount });
          }
        }
      });
    }
    var priceBeforeVatPerSeat = Math.max(0, parseFloat((basePricePerSeat - totalDiscountPerSeat).toFixed(2)));
    var vatPerSeat = parseFloat((priceBeforeVatPerSeat * 0.07).toFixed(2));
    var finalPerSeat = parseFloat((priceBeforeVatPerSeat + vatPerSeat).toFixed(2));
    var basePrice = parseFloat((basePricePerSeat * seats).toFixed(2));
    var totalDiscount = parseFloat((totalDiscountPerSeat * seats).toFixed(2));
    var priceBeforeVat = parseFloat((priceBeforeVatPerSeat * seats).toFixed(2));
    var vatAmount = parseFloat((vatPerSeat * seats).toFixed(2));
    var finalPrice = parseFloat((finalPerSeat * seats).toFixed(2));

    var fmt = function(n) { return n.toLocaleString('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }); };
    var elBase = document.getElementById('display_base_price');
    var elDiscount = document.getElementById('display_discount');
    var elBeforeVat = document.getElementById('display_price_before_vat');
    var elVat = document.getElementById('display_vat');
    var elFinal = document.getElementById('display_final_price');
    var elDetails = document.getElementById('discount_details');
    if (elBase) elBase.textContent = fmt(basePrice);
    if (elDiscount) elDiscount.textContent = fmt(totalDiscount);
    if (elBeforeVat) elBeforeVat.textContent = fmt(priceBeforeVat);
    if (elVat) elVat.textContent = fmt(vatAmount);
    if (elFinal) elFinal.textContent = fmt(finalPrice);
    if (elDetails) {
      if (discountDetails.length > 0) {
        elDetails.innerHTML = discountDetails.map(function(d) {
          var totalAmount = parseFloat((d.amount * seats).toFixed(2));
          return '<div class="text-start">• ' + d.name + ': -' + fmt(totalAmount) + ' ฿</div>';
        }).join('');
      } else {
        elDetails.innerHTML = '';
      }
    }
  }

  if (basePriceInput) {
    basePriceInput.addEventListener('input', calculatePrice);
    basePriceInput.addEventListener('change', calculatePrice);
  }
  if (seatsInput) {
    seatsInput.addEventListener('input', calculatePrice);
    seatsInput.addEventListener('change', calculatePrice);
  }
  if (promotionCheckboxes && promotionCheckboxes.length) {
    promotionCheckboxes.forEach(function(cb) { cb.addEventListener('change', calculatePrice); });
  }
  calculatePrice();
});
document.addEventListener('turbo:load', function() {
  if (document.querySelector('#attendee-new-form')) {
    var ev = new Event('DOMContentLoaded');
    document.dispatchEvent(ev);
  }
});
</script>
<% end %>
