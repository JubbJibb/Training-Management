<% attendee = local_assigns[:attendee] %>
<%= odt_card(title: "Profile", icon: "person", extra_class: "attendee-view-card") do %>
  <div class="attendee-view-grid">
    <div class="attendee-view-row">
      <span class="attendee-view-label">Name</span>
      <span class="attendee-view-value"><%= attendee.name %></span>
    </div>
    <div class="attendee-view-row">
      <span class="attendee-view-label">Email</span>
      <span class="attendee-view-value"><%= attendee.email %></span>
    </div>
    <div class="attendee-view-row">
      <span class="attendee-view-label">Phone</span>
      <span class="attendee-view-value"><%= attendee.phone.presence || "—" %></span>
    </div>
    <div class="attendee-view-row">
      <span class="attendee-view-label">Type</span>
      <span class="attendee-view-value"><%= attendee.participant_type == "Corp" ? "Corporate" : "Individual" %></span>
    </div>
    <% if attendee.participant_type == "Corp" && attendee.company.present? %>
      <div class="attendee-view-row">
        <span class="attendee-view-label">Company</span>
        <span class="attendee-view-value"><%= attendee.company %></span>
      </div>
    <% end %>
  </div>
<% end %>
