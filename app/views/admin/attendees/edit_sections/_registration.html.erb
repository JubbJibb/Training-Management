<div class="attendee-edit-surface">
  <div class="attendee-edit-surface__header">
    <i class="bi bi-calendar-check" aria-hidden="true"></i>
    <span>Registration</span>
  </div>
  <div class="attendee-edit-surface__body">
    <div class="attendee-edit-fields attendee-edit-fields--grid">
      <div class="attendee-edit-field">
        <%= f.label :status, "Status", class: "attendee-edit-field__label" %>
        <%= f.select :status, [["Attendee", "attendee"], ["Potential", "potential"]],
            { selected: @attendee.status || "attendee" },
            { class: "form-select form-control-odt" } %>
      </div>
      <div class="attendee-edit-field">
        <%= f.label :source_channel, "Source", class: "attendee-edit-field__label" %>
        <%= f.text_field :source_channel, class: "form-control form-control-odt", placeholder: "e.g. Website, Email", list: "source_channel_list" %>
        <datalist id="source_channel_list">
          <% (defined?(@source_channel_options) && @source_channel_options || []).each do |opt| %>
            <option value="<%= opt %>">
          <% end %>
        </datalist>
        <p class="attendee-edit-field__hint mt-1 mb-0">ช่องทางที่มา — เลือกจากรายการหรือพิมพ์เพิ่มเอง</p>
      </div>
      <div class="attendee-edit-field" id="seats-field" style="<%= 'display: none;' unless @attendee.participant_type == 'Corp' %>">
        <%= f.label :seats, "Seats", class: "attendee-edit-field__label" %>
        <%= f.number_field :seats, class: "form-control form-control-odt", min: 1, value: @attendee.participant_type == "Corp" ? (@attendee.seats || 1) : 1, readonly: (@attendee.participant_type == "Indi") %>
      </div>
      <div class="attendee-edit-field" id="seats-indi-hint" style="<%= 'display: none;' if @attendee.participant_type == 'Corp' %>">
        <span class="attendee-edit-field__hint">Seats: 1 (Individual)</span>
      </div>
      <div class="attendee-edit-field">
        <%= f.label :total_classes, "Classes attended", class: "attendee-edit-field__label" %>
        <%= f.number_field :total_classes, class: "form-control form-control-odt", min: 0, value: @attendee.total_classes || 0 %>
      </div>
    </div>
  </div>
</div>
