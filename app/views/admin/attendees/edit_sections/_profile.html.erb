<div class="attendee-edit-surface">
  <div class="attendee-edit-surface__header">
    <i class="bi bi-person" aria-hidden="true"></i>
    <span>Profile</span>
  </div>
  <div class="attendee-edit-surface__body">
    <div class="attendee-edit-fields attendee-edit-fields--grid">
      <div class="attendee-edit-field">
        <%= f.label :name, class: "attendee-edit-field__label" %>
        <%= f.text_field :name, class: "form-control form-control-odt", required: true, autofocus: true %>
      </div>
      <div class="attendee-edit-field">
        <%= f.label :email, class: "attendee-edit-field__label" %>
        <%= f.email_field :email, class: "form-control form-control-odt", required: true %>
      </div>
      <div class="attendee-edit-field">
        <%= f.label :phone, "Phone", class: "attendee-edit-field__label" %>
        <%= f.telephone_field :phone, class: "form-control form-control-odt" %>
      </div>
      <div class="attendee-edit-field">
        <%= f.label :participant_type, "Type", class: "attendee-edit-field__label" %>
        <%= f.select :participant_type, [["Individual", "Indi"], ["Corporate", "Corp"]],
            { selected: @attendee.participant_type || "Indi" },
            { class: "form-select form-control-odt", id: "participant_type_select" } %>
      </div>
      <div class="attendee-edit-field" id="company-field" style="<%= 'display: none;' unless @attendee.participant_type == 'Corp' %>">
        <%= f.label :company, "Company", class: "attendee-edit-field__label" %>
        <%= f.text_field :company, class: "form-control form-control-odt" %>
      </div>
    </div>
  </div>
</div>
