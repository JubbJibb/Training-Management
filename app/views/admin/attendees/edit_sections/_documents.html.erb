<div class="attendee-edit-surface">
  <div class="attendee-edit-surface__header">
    <i class="bi bi-file-earmark-text" aria-hidden="true"></i>
    <span>Documents & Payment</span>
  </div>
  <div class="attendee-edit-surface__body">
    <div class="attendee-edit-fields attendee-edit-fields--grid">
      <div class="attendee-edit-field">
        <%= f.label :payment_status, "Payment status", class: "attendee-edit-field__label" %>
        <%= f.select :payment_status, [["Pending", "Pending"], ["Paid", "Paid"]], { selected: @attendee.payment_status || "Pending" }, { class: "form-select form-control-odt" } %>
      </div>
      <div class="attendee-edit-field">
        <%= f.label :document_status, "Document status", class: "attendee-edit-field__label" %>
        <%= f.select :document_status, [["", ""], ["QT", "QT"], ["INV", "INV"], ["Receipt", "Receipt"]], { selected: @attendee.document_status }, { class: "form-select form-control-odt" } %>
      </div>
      <div class="attendee-edit-field">
        <%= f.label :due_date, "Due date", class: "attendee-edit-field__label" %>
        <%= f.date_field :due_date, class: "form-control form-control-odt" %>
      </div>
      <div class="attendee-edit-field">
        <label class="attendee-edit-field__label">Payment slip</label>
        <div class="attendee-edit-dropzone" id="attendee-dropzone">
          <div class="attendee-edit-dropzone__area">
            <input type="file" name="attendee[payment_slips][]" class="attendee-edit-dropzone__input" accept="image/*,.pdf" multiple>
            <span class="attendee-edit-dropzone__placeholder">Drag and drop or click to upload</span>
          </div>
          <% if @attendee.payment_slips.attached? %>
            <div class="attendee-edit-dropzone__preview">
              <% @attendee.payment_slips.each do |slip| %>
                <div class="attendee-edit-dropzone__thumb">
                  <% if slip.content_type&.start_with?("image/") %>
                    <%= image_tag slip, class: "img-fluid" %>
                  <% else %>
                    <i class="bi bi-file-earmark-pdf attendee-edit-dropzone__pdf-icon" aria-hidden="true"></i>
                  <% end %>
                  <span><%= slip.filename %></span>
                  <%= link_to rails_blob_path(slip), target: "_blank", class: "attendee-edit-dropzone__view" do %>View<% end %>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
    <details class="attendee-edit-more-details mt-3">
      <summary class="attendee-edit-more-details__summary">More details</summary>
      <div class="attendee-edit-more-details__body pt-3">
        <div class="attendee-edit-fields attendee-edit-fields--grid">
          <div class="attendee-edit-field">
            <%= f.label :quotation_no, "Quotation No.", class: "attendee-edit-field__label" %>
            <%= f.text_field :quotation_no, class: "form-control form-control-odt", placeholder: "e.g. QT-2026-001" %>
          </div>
          <div class="attendee-edit-field">
            <%= f.label :invoice_no, "Invoice No.", class: "attendee-edit-field__label" %>
            <%= f.text_field :invoice_no, class: "form-control form-control-odt", placeholder: "e.g. INV-2026-001" %>
          </div>
          <div class="attendee-edit-field">
            <%= f.label :receipt_no, "Receipt No.", class: "attendee-edit-field__label" %>
            <%= f.text_field :receipt_no, class: "form-control form-control-odt", placeholder: "e.g. RCP-2026-001" %>
          </div>
          <div class="attendee-edit-field">
            <%= f.label :payment_date, "Payment date", class: "attendee-edit-field__label" %>
            <%= f.date_field :payment_date, class: "form-control form-control-odt", value: @attendee.payment_date&.strftime("%Y-%m-%d") %>
          </div>
          <div class="attendee-edit-field attendee-edit-field--full">
            <%= f.label :notes, "Internal note", class: "attendee-edit-field__label" %>
            <%= f.text_area :notes, class: "form-control form-control-odt", rows: 2 %>
          </div>
        </div>
      </div>
    </details>
  </div>
</div>
