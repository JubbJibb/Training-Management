<%
  customers = local_assigns[:customers] || []
  segment = local_assigns[:segment].to_s.presence || "all"
  sort = local_assigns[:sort].to_s.presence
  direction = local_assigns[:direction].to_s.downcase == "asc" ? "asc" : "desc"
  base_params = { q: params[:q].to_s.presence, segment: segment, top_n: params[:top_n].to_s.presence }.compact
%>
<div class="customers-ledger attendees-ledger">
  <% if customers.any? %>
    <div class="attendees-ledger__table-wrap">
      <table class="attendees-ledger__table" role="table" aria-label="Customers">
        <thead>
          <tr>
            <th scope="col" class="attendees-ledger__th attendees-ledger__th--check" style="width: 2.5rem;">
              <label class="attendees-ledger__check-label">
                <input type="checkbox" data-customer-email-select-target="selectAll" data-action="change->customer-email-select#toggleAll" aria-label="เลือกทั้งหมด">
              </label>
            </th>
            <th scope="col" class="attendees-ledger__th attendees-ledger__th--name">
              <%= link_to admin_customers_path(base_params.merge(sort: "customer", direction: (sort == "customer" && direction == "asc" ? "desc" : "asc"))), data: { turbo_frame: "customers_table" }, class: "attendees-ledger__sort-link #{sort == "customer" ? "attendees-ledger__sort-link--active" : ""}" do %>
                Customer <%= sort == "customer" ? (direction == "asc" ? "↑" : "↓") : "" %>
              <% end %>
            </th>
            <th scope="col" class="attendees-ledger__th attendees-ledger__th--type">
              <%= link_to admin_customers_path(base_params.merge(sort: "type", direction: (sort == "type" && direction == "asc" ? "desc" : "asc"))), data: { turbo_frame: "customers_table" }, class: "attendees-ledger__sort-link #{sort == "type" ? "attendees-ledger__sort-link--active" : ""}" do %>
                Type <%= sort == "type" ? (direction == "asc" ? "↑" : "↓") : "" %>
              <% end %>
            </th>
            <th scope="col" class="attendees-ledger__th attendees-ledger__th--seats">
              <%= link_to admin_customers_path(base_params.merge(sort: "times_attended", direction: (sort == "times_attended" && direction == "asc" ? "desc" : "asc"))), data: { turbo_frame: "customers_table" }, class: "attendees-ledger__sort-link #{sort == "times_attended" ? "attendees-ledger__sort-link--active" : ""}" do %>
                Times attended <%= sort == "times_attended" ? (direction == "asc" ? "↑" : "↓") : "" %>
              <% end %>
            </th>
            <th scope="col" class="attendees-ledger__th attendees-ledger__th--payment-date">
              <%= link_to admin_customers_path(base_params.merge(sort: "last_attended", direction: (sort == "last_attended" && direction == "asc" ? "desc" : "asc"))), data: { turbo_frame: "customers_table" }, class: "attendees-ledger__sort-link #{sort == "last_attended" ? "attendees-ledger__sort-link--active" : ""}" do %>
                Last attended <%= sort == "last_attended" ? (direction == "asc" ? "↑" : "↓") : "" %>
              <% end %>
            </th>
            <th scope="col" class="attendees-ledger__th attendees-ledger__th--amount">
              <%= link_to admin_customers_path(base_params.merge(sort: "total_spent", direction: (sort == "total_spent" && direction == "asc" ? "desc" : "asc"))), data: { turbo_frame: "customers_table" }, class: "attendees-ledger__sort-link #{sort == "total_spent" ? "attendees-ledger__sort-link--active" : ""}" do %>
                Total spent (Net) <%= sort == "total_spent" ? (direction == "asc" ? "↑" : "↓") : "" %>
              <% end %>
            </th>
            <th scope="col" class="attendees-ledger__th attendees-ledger__th--amount">
              <%= link_to admin_customers_path(base_params.merge(sort: "outstanding", direction: (sort == "outstanding" && direction == "asc" ? "desc" : "asc"))), data: { turbo_frame: "customers_table" }, class: "attendees-ledger__sort-link #{sort == "outstanding" ? "attendees-ledger__sort-link--active" : ""}" do %>
                Outstanding <%= sort == "outstanding" ? (direction == "asc" ? "↑" : "↓") : "" %>
              <% end %>
            </th>
            <th scope="col" class="attendees-ledger__th attendees-ledger__th--seats">
              <%= link_to admin_customers_path(base_params.merge(sort: "seats_total", direction: (sort == "seats_total" && direction == "asc" ? "desc" : "asc"))), data: { turbo_frame: "customers_table" }, class: "attendees-ledger__sort-link #{sort == "seats_total" ? "attendees-ledger__sort-link--active" : ""}" do %>
                Seats <%= sort == "seats_total" ? (direction == "asc" ? "↑" : "↓") : "" %>
              <% end %>
            </th>
            <th scope="col" class="attendees-ledger__th attendees-ledger__th--source">Billing &amp; Tax</th>
            <th scope="col" class="attendees-ledger__th attendees-ledger__th--actions">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% customers.each do |c| %>
            <%= render "admin/customers/row", customer: c, segment: segment, sort: sort, direction: direction, base_params: base_params %>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <%= render "shared/empty_state", message: "ไม่พบข้อมูล", icon: "people" %>
  <% end %>
</div>
