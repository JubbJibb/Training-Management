<% content_for :title, "Bundle Deal - สรุปการชำระเงิน - #{@customer.company_name}" %>

<%= render "components/odt/page_header", title: "Bundle Deal – สรุปการชำระเงิน", subtitle: "ลูกค้า #{@customer.company_name} · สมัคร #{@training_classes.size} คลาส", icon: "receipt" do %>
  <%= link_to register_for_class_admin_customer_path(@customer), class: "odt-btn odt-btn--secondary odt-btn--sm" do %>
    <i class="bi bi-arrow-left" aria-hidden="true"></i> กลับไปเลือกคลาส
  <% end %>
<% end %>

<div class="card mb-4">
  <div class="card-body">
    <h5 class="card-title"><i class="bi bi-person" aria-hidden="true"></i> ผู้ลงทะเบียน</h5>
    <p class="mb-0 text-muted"><%= @customer.name %> · <%= @customer.email %> · <%= @customer.company.presence || "—" %></p>
  </div>
</div>

<div class="card mb-4">
  <div class="card-header">
    <h5 class="mb-0"><i class="bi bi-tag" aria-hidden="true"></i> ส่วนลด Bundle Deal</h5>
  </div>
  <div class="card-body">
    <%= form_with url: bundle_deal_summary_admin_customer_path(@customer), method: :get, local: true, class: "row g-2 align-items-end" do |f| %>
      <% @training_classes.each do |tc| %>
        <%= hidden_field_tag "class_ids[]", tc.id %>
      <% end %>
      <div class="col-auto">
        <label class="form-label small mb-0">ประเภทส่วนลด</label>
        <%= select_tag "discount_type", options_for_select([["ไม่มี", "none"], ["ลดเป็นร้อยละ (%)", "percent"], ["ลดเป็นเงิน (บาท)", "fixed"], ["กำหนดราคา Final รวมทั้ง Bundle (บาท)", "fixed_total"]], @discount_type), class: "form-select form-select-sm" %>
      </div>
      <div class="col-auto" id="bundle-discount-value-wrap" style="<%= 'display: none;' if @discount_type == 'none' %>">
        <label class="form-label small mb-0"><%= discount_value_label(@discount_type) %></label>
        <%= number_field_tag "discount_value", @discount_value.presence, min: 0, step: step_for_discount_type(@discount_type), class: "form-control form-control-sm", style: "width: 120px;", placeholder: placeholder_for_discount_type(@discount_type) %>
      </div>
      <div class="col-auto">
        <button type="submit" class="odt-btn odt-btn--secondary odt-btn--sm">
          <i class="bi bi-calculator" aria-hidden="true"></i> คำนวณใหม่
        </button>
      </div>
    <% end %>
    <% if @discount_type != "none" && (@grand_discount.to_f.nonzero? || @discount_type == "fixed_total") %>
      <p class="text-success small mt-2 mb-0">
        <% if @discount_type == "fixed_total" && @discount_value.present? %>
          <i class="bi bi-check-circle" aria-hidden="true"></i> กำหนดราคา Final รวม <strong><%= @training_classes.size %> คลาส = ฿<%= number_with_delimiter(@grand_total) %></strong>
        <% else %>
          <i class="bi bi-check-circle" aria-hidden="true"></i> ส่วนลด Bundle รวม <strong>฿<%= number_with_delimiter(@grand_discount) %></strong>
        <% end %>
      </p>
    <% end %>
  </div>
</div>

<%# Payment Summary แบบเดียวกับหน้า attendee edit (Copy / PDF) %>
<div class="attendee-summary-view mb-4">
  <%= odt_card(title: "Payment Summary", icon: "receipt", extra_class: "payment-summary-card financials-payment-summary-card") do %>
    <%= render "admin/customers/bundle_payment_summary",
          customer: @customer,
          rows: @rows,
          grand_base: @grand_base,
          grand_discount: @grand_discount,
          grand_before_vat: @grand_before_vat,
          grand_vat: @grand_vat,
          grand_total: @grand_total %>
    <div class="payment-summary-card__actions">
      <button type="button" class="odt-btn odt-btn--secondary odt-btn--sm payment-summary-card__btn" id="bundle-payment-summary-copy" title="Copy summary to clipboard">
        <i class="bi bi-clipboard" aria-hidden="true"></i> Copy Summary
      </button>
      <button type="button" class="odt-btn odt-btn--ghost odt-btn--sm payment-summary-card__btn" id="bundle-payment-summary-pdf" title="Print / Save as PDF">
        <i class="bi bi-file-earmark-pdf" aria-hidden="true"></i> Download PDF
      </button>
    </div>
  <% end %>
</div>

<div class="card">
  <div class="card-header d-flex justify-content-between align-items-center">
    <h5 class="mb-0"><i class="bi bi-calculator" aria-hidden="true"></i> สรุปการชำระเงินตามคลาส</h5>
  </div>
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead class="table-light">
          <tr>
            <th>หลักสูตร</th>
            <th>วันที่</th>
            <th class="text-end">ราคาเริ่มต้น</th>
            <th class="text-end">ส่วนลด</th>
            <th class="text-end">ก่อน VAT</th>
            <th class="text-end">VAT (7%)</th>
            <th class="text-end">รวม (บาท)</th>
          </tr>
        </thead>
        <tbody>
          <% @rows.each do |row| %>
            <% tc = row[:training_class] %>
            <tr>
              <td><strong><%= tc.title %></strong></td>
              <td><%= tc.date.strftime("%d %b %Y") %></td>
              <td class="text-end"><%= number_with_delimiter(row[:base]) %></td>
              <td class="text-end"><%= number_with_delimiter(row[:discount]) %></td>
              <td class="text-end"><%= number_with_delimiter(row[:before_vat]) %></td>
              <td class="text-end"><%= row[:vat_excluded] ? "—" : number_with_delimiter(row[:vat_amount]) %></td>
              <td class="text-end"><strong><%= number_with_delimiter(row[:total]) %></strong></td>
            </tr>
          <% end %>
        </tbody>
        <tfoot class="table-light">
          <tr>
            <th colspan="2" class="text-end">รวมทั้งสิ้น</th>
            <th class="text-end"><%= number_with_delimiter(@grand_base) %></th>
            <th class="text-end"><%= number_with_delimiter(@grand_discount) %></th>
            <th class="text-end"><%= number_with_delimiter(@grand_before_vat) %></th>
            <th class="text-end"><%= number_with_delimiter(@grand_vat) %></th>
            <th class="text-end"><strong class="text-primary">฿<%= number_with_delimiter(@grand_total) %></strong></th>
          </tr>
        </tfoot>
      </table>
    </div>
  </div>
  <div class="card-footer d-flex justify-content-between align-items-center flex-wrap gap-2">
    <%= link_to register_for_class_admin_customer_path(@customer), class: "odt-btn odt-btn--secondary odt-btn--sm" do %>
      <i class="bi bi-arrow-left" aria-hidden="true"></i> กลับไปเลือกคลาส
    <% end %>
    <%= form_with url: bundle_deal_register_admin_customer_path(@customer), method: :post, data: { turbo_confirm: "ยืนยันสมัคร #{@customer.name} ใน #{@training_classes.size} คลาส?" } do |f| %>
      <% @training_classes.each do |tc| %>
        <%= hidden_field_tag "class_ids[]", tc.id %>
      <% end %>
      <%= hidden_field_tag "discount_type", @discount_type %>
      <%= hidden_field_tag "discount_value", @discount_value %>
      <button type="submit" class="odt-btn odt-btn--primary" data-turbo-confirm="ยืนยันสมัคร <%= @customer.name %> ใน <%= @training_classes.size %> คลาส?">
        <i class="bi bi-check-lg" aria-hidden="true"></i> ยืนยันสมัคร Bundle
      </button>
    <% end %>
  </div>
</div>

<%= content_for :footer_scripts do %>
<script>
document.addEventListener('DOMContentLoaded', function() {
  var discountType = document.querySelector('select[name="discount_type"]');
  var wrap = document.getElementById('bundle-discount-value-wrap');
  var valueInput = document.querySelector('input[name="discount_value"]');
  var label = wrap ? wrap.querySelector('.form-label') : null;
  if (discountType && wrap) {
    discountType.addEventListener('change', function() {
      var v = this.value;
      if (v === 'none') {
        wrap.style.display = 'none';
        if (valueInput) valueInput.value = '';
      } else {
        wrap.style.display = 'block';
        var labels = { percent: 'ร้อยละ (%)', fixed: 'จำนวนเงินส่วนลด (บาท)', fixed_total: 'ราคา Final รวม (บาท)' };
        if (label) label.textContent = labels[v] || 'จำนวนเงิน (บาท)';
        if (valueInput) {
          valueInput.step = (v === 'percent') ? '0.5' : '1';
          var placeholders = { percent: 'เช่น 10', fixed: 'เช่น 500', fixed_total: 'เช่น 21,400' };
          valueInput.placeholder = placeholders[v] || 'เช่น 500';
        }
      }
    });
  }

  var copyBtn = document.getElementById('bundle-payment-summary-copy');
  if (copyBtn) {
    copyBtn.addEventListener('click', function() {
      var el = document.getElementById('payment-summary-content');
      if (!el) return;
      var text = el.innerText || el.textContent || '';
      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(text).then(function() {
          copyBtn.innerHTML = '<i class="bi bi-check2" aria-hidden="true"></i> Copied';
          setTimeout(function() { copyBtn.innerHTML = '<i class="bi bi-clipboard" aria-hidden="true"></i> Copy Summary'; }, 2000);
        });
      }
    });
  }
  var pdfBtn = document.getElementById('bundle-payment-summary-pdf');
  if (pdfBtn) {
    pdfBtn.addEventListener('click', function() {
      window.print();
    });
  }
});
</script>
<% end %>
