<%
  training_class = local_assigns[:training_class] || @training_class
  records = local_assigns[:records] || []
%>
<div class="attendance-history-table-wrap">
  <% if records.empty? %>
    <div class="attendance-table-empty">
      <p class="attendance-table-empty__text">ไม่มีรายการบันทึกการเช็กชื่อ</p>
    </div>
  <% else %>
    <table class="attendance-table attendance-history-table" role="table">
      <thead class="attendance-table__head">
        <tr>
          <th scope="col" class="attendance-table__th">วันที่</th>
          <th scope="col" class="attendance-table__th">ชั่วโมงเรียน</th>
          <th scope="col" class="attendance-table__th">บันทึกโดย</th>
          <th scope="col" class="attendance-table__th">อัปเดตล่าสุด</th>
          <th scope="col" class="attendance-table__th">สถานะ</th>
          <th scope="col" class="attendance-table__th">การดำเนินการ</th>
        </tr>
      </thead>
      <tbody class="attendance-table__body">
        <% records.each do |record| %>
          <tr class="attendance-table__row">
            <td class="attendance-table__td"><%= record.attendance_date.strftime("%d/%m/%Y") %></td>
            <td class="attendance-table__td"><%= record.learning_hour %></td>
            <td class="attendance-table__td"><%= record.recorded_by&.email || "—" %></td>
            <td class="attendance-table__td"><%= l(record.updated_at, format: :short) %></td>
            <td class="attendance-table__td"><span class="attendance-tab__badge attendance-tab__badge--saved">บันทึกแล้ว</span></td>
            <td class="attendance-table__td">
              <%= link_to "ดู", admin_class_workspace_attendance_record_path(training_class, record), class: "attendance-history-table__link", data: { turbo_frame: "attendance_history_detail" } %>
              <%= link_to "แก้ไข", admin_class_workspace_attendance_path(training_class, attendance_date: record.attendance_date.strftime("%Y-%m-%d"), learning_hour: record.learning_hour, edit_record_id: record.id, tab: "check"), class: "attendance-history-table__link", data: { turbo_frame: "_top" } %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>
</div>
<%= turbo_frame_tag "attendance_history_detail" %>
