<%
  sort_column = @sort_column.presence || "date"
  sort_direction = @sort_direction.presence == "desc" ? "desc" : "asc"
  sort_params = request.query_parameters.slice("tab", "instructor", "date_from", "date_to", "class_type").compact
  index_path = @index_path.presence || admin_training_classes_path
%>
<%= turbo_frame_tag "tc_index_table" do %>
  <% if @training_classes.any? %>
    <div class="tc-index-saas-table-wrap">
      <table class="tc-index-saas-table odt-premium-table" role="table" aria-label="Training classes">
        <colgroup>
          <col style="width: 24%;">
          <col style="width: 10%;">
          <col style="width: 10%;">
          <col style="width: 16%;">
          <col style="width: 12%;">
          <col style="width: 12%;">
          <col style="width: 16%;">
        </colgroup>
        <thead>
          <tr>
            <th scope="col" class="tc-saas-th tc-saas-th--class">
              <%= link_to index_path, **sort_params.merge(sort: "title", direction: (sort_column == "title" && sort_direction == "asc" ? "desc" : "asc")), class: "tc-saas-th__sort-link", data: { turbo_frame: "tc_index_table" } do %>
                Class <%= sort_column == "title" ? (sort_direction == "asc" ? "↑" : "↓") : "" %>
              <% end %>
            </th>
            <th scope="col" class="tc-saas-th tc-saas-th--date">
              <%= link_to index_path, **sort_params.merge(sort: "date", direction: (sort_column == "date" && sort_direction == "asc" ? "desc" : "asc")), class: "tc-saas-th__sort-link", data: { turbo_frame: "tc_index_table" } do %>
                Date <%= sort_column == "date" ? (sort_direction == "asc" ? "↑" : "↓") : "" %>
              <% end %>
            </th>
            <th scope="col" class="tc-saas-th">Status</th>
            <th scope="col" class="tc-saas-th tc-saas-th--fill">
              <%= link_to index_path, **sort_params.merge(sort: "fill", direction: (sort_column == "fill" && sort_direction == "asc" ? "desc" : "asc")), class: "tc-saas-th__sort-link", data: { turbo_frame: "tc_index_table" } do %>
                Fill <%= sort_column == "fill" ? (sort_direction == "asc" ? "↑" : "↓") : "" %>
              <% end %>
            </th>
            <th scope="col" class="tc-saas-th tc-saas-th--revenue">
              <%= link_to index_path, **sort_params.merge(sort: "revenue", direction: (sort_column == "revenue" && sort_direction == "asc" ? "desc" : "asc")), class: "tc-saas-th__sort-link", data: { turbo_frame: "tc_index_table" } do %>
                Revenue <%= sort_column == "revenue" ? (sort_direction == "asc" ? "↑" : "↓") : "" %>
              <% end %>
            </th>
            <th scope="col" class="tc-saas-th tc-saas-th--instructor">
              <%= link_to index_path, **sort_params.merge(sort: "instructor", direction: (sort_column == "instructor" && sort_direction == "asc" ? "desc" : "asc")), class: "tc-saas-th__sort-link", data: { turbo_frame: "tc_index_table" } do %>
                Instructor <%= sort_column == "instructor" ? (sort_direction == "asc" ? "↑" : "↓") : "" %>
              <% end %>
            </th>
            <th scope="col" class="tc-saas-th tc-saas-th--actions">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @training_classes.each do |tc| %>
            <%= render "admin/training_classes/table_row", tc: tc, sort_column: sort_column, sort_direction: sort_direction, sort_params: sort_params, index_path: index_path %>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="tc-index-empty">
      <%= render "shared/empty_state", message: @empty_state_message, icon: @empty_state_icon %>
      <% if @tab == "upcoming" %>
        <%= link_to "Create training class", new_admin_training_class_path, class: "odt-btn odt-btn--primary odt-btn--sm" %>
      <% end %>
    </div>
  <% end %>
<% end %>
