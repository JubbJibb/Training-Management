<div class="promo-mgmt-section">
  <%= render "components/odt/section_header", title: "Active Promotions", subtitle: "Edit, duplicate or deactivate" %>

  <div class="promo-mgmt-section__body">
    <% if @promotions.any? %>
      <div class="tc-index-content">
        <div class="tc-index-saas-table-wrap">
          <table class="tc-index-saas-table odt-premium-table" role="table" aria-label="Active promotions">
            <colgroup>
              <col style="width: 14%;">
              <col style="width: 10%;">
              <col style="width: 14%;">
              <col style="width: 8%;">
              <col style="width: 12%;">
              <col style="width: 12%;">
              <col style="width: 8%;">
              <col style="width: 10%;">
              <col style="width: 12%;">
            </colgroup>
            <thead>
              <tr>
                <th scope="col" class="tc-saas-th">Name</th>
                <th scope="col" class="tc-saas-th">Type</th>
                <th scope="col" class="tc-saas-th">Discount logic</th>
                <th scope="col" class="tc-saas-th tc-saas-th--revenue">Usage</th>
                <th scope="col" class="tc-saas-th tc-saas-th--revenue">Revenue impact</th>
                <th scope="col" class="tc-saas-th tc-saas-th--revenue">Discount cost</th>
                <th scope="col" class="tc-saas-th">Segment</th>
                <th scope="col" class="tc-saas-th">Status</th>
                <th scope="col" class="tc-saas-th tc-saas-th--actions">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% @promotions.each do |p| %>
                <% perf = (@promo_performance || []).find { |r| r[:id] == p.id } %>
                <% usage = (@promo_usage || {}).fetch(p.id, 0) %>
                <tr class="tc-saas-tr">
                  <td class="tc-saas-td tc-saas-td--class">
                    <div class="tc-saas-class-cell">
                      <%= link_to p.name, edit_admin_setting_path(p), class: "tc-saas-class-link", data: { turbo_frame: "_top" } %>
                    </div>
                  </td>
                  <td class="tc-saas-td"><%= p.discount_type.humanize %></td>
                  <td class="tc-saas-td"><%= p.discount_description %></td>
                  <td class="tc-saas-td tc-saas-td--revenue">
                    <span class="tc-saas-revenue"><%= number_with_delimiter(usage, delimiter: ",") %></span>
                  </td>
                  <td class="tc-saas-td tc-saas-td--revenue">
                    <span class="tc-saas-revenue"><%= perf ? number_to_thb(perf[:revenue_generated].to_f) : "—" %></span>
                  </td>
                  <td class="tc-saas-td tc-saas-td--revenue">
                    <span class="tc-saas-revenue"><%= perf ? number_to_thb(perf[:total_discount_cost].to_f) : "—" %></span>
                  </td>
                  <td class="tc-saas-td">All</td>
                  <td class="tc-saas-td">
                    <%= p.active? ? odt_badge("Active", variant: :success, size: :sm) : odt_badge("Inactive", variant: :neutral, size: :sm) %>
                  </td>
                  <td class="tc-saas-td tc-saas-td--actions">
                    <div class="tc-saas-actions">
                      <%= link_to edit_admin_setting_path(p), class: "tc-saas-actions-btn", title: "Edit", aria: { label: "Edit" }, data: { turbo_frame: "_top" } do %><i class="bi bi-pencil" aria-hidden="true"></i><% end %>
                      <%= link_to new_admin_setting_path(clone_from: p.id), class: "tc-saas-actions-btn", title: "Duplicate", aria: { label: "Duplicate" } do %><i class="bi bi-copy" aria-hidden="true"></i><% end %>
                      <%= link_to admin_setting_path(p), data: { turbo_method: :delete, turbo_confirm: "Delete this promotion?" }, class: "tc-saas-actions-btn tc-saas-actions-btn--danger", title: "Delete", aria: { label: "Delete" } do %><i class="bi bi-trash" aria-hidden="true"></i><% end %>
                    </div>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    <% else %>
      <%= render "shared/empty_state", message: "No promotions yet. Create your first promotion to get started.", icon: "tag" %>
      <p class="mt-3"><%= link_to "New Promotion", new_admin_setting_path, class: "odt-btn odt-btn--primary odt-btn--sm" %></p>
    <% end %>
  </div>
</div>
