<%
  tc = local_assigns[:training_class] || @training_class
  capacity = local_assigns[:capacity] || tc.max_attendees.to_i
  time_str = [tc.start_time, tc.end_time].compact.any? ? [tc.start_time&.strftime("%I:%M %p"), tc.end_time&.strftime("%I:%M %p")].compact.join(" – ") : "—"
  date_str = tc.date.strftime("%b %d, %Y")
  date_str += " – #{tc.end_date.strftime("%b %d, %Y")}" if tc.end_date.present? && tc.end_date != tc.date
  desc = tc.description.present? ? strip_tags(tc.description) : nil
  needs_toggle = desc && desc.length > 120
  subtitle_parts = [date_str, time_str, tc.location.presence].compact
  subtitle_str = subtitle_parts.any? ? subtitle_parts.join(" · ") : "Schedule and venue"
%>
<div class="insight-card insight-card--class-details">
  <div class="insight-card__header">
    <div class="insight-card__accent"></div>
    <div class="insight-card__head-text">
      <h3 class="insight-card__title">Class Details</h3>
      <p class="insight-card__subtitle"><%= subtitle_str %></p>
    </div>
  </div>
  <div class="insight-card__body">
    <%= render "admin/class_workspace/sections/overview/public_status_row", training_class: tc %>
    <div class="insight-progress-row">
      <span class="insight-progress-row__label">Instructor</span>
      <span class="insight-progress-row__value"><%= tc.instructor.presence || "—" %></span>
    </div>
    <div class="insight-progress-row">
      <span class="insight-progress-row__label">Duration</span>
      <span class="insight-progress-row__value"><%= tc.duration.presence || "—" %></span>
    </div>
    <div class="insight-progress-row">
      <span class="insight-progress-row__label">Capacity</span>
      <span class="insight-progress-row__value"><%= capacity.positive? ? "#{capacity} seats" : "—" %></span>
    </div>
    <div class="insight-progress-row insight-progress-row--pricing">
      <span class="insight-progress-row__label">Price / seat</span>
      <div class="insight-progress-row__value insight-seat-price-breakdown">
        <% if tc.price.blank? || tc.price.to_f.zero? %>
          <span>—</span>
        <% elsif tc.vat_excluded? %>
          <span><%= number_to_thb(tc.seat_price_ex_vat) %></span>
          <span class="insight-seat-price-breakdown__note text-muted small">ไม่คิด VAT 7%</span>
        <% else %>
          <div class="insight-seat-price-breakdown__inc"><%= number_to_thb(tc.seat_price_inc_vat) %> <span class="text-muted small fw-normal">รวม VAT</span></div>
          <div class="insight-seat-price-breakdown__lines small">
            <div class="insight-seat-price-breakdown__line d-flex justify-content-between gap-2"><span class="text-muted">ก่อน VAT</span><span><%= number_to_thb(tc.seat_price_ex_vat) %></span></div>
            <div class="insight-seat-price-breakdown__line d-flex justify-content-between gap-2"><span class="text-muted">VAT 7%</span><span><%= number_to_thb(tc.seat_vat_amount) %></span></div>
            <div class="insight-seat-price-breakdown__line insight-seat-price-breakdown__line--total d-flex justify-content-between gap-2 pt-1 mt-1 border-top"><span class="fw-semibold">รวม VAT</span><span class="fw-semibold"><%= number_to_thb(tc.seat_price_inc_vat) %></span></div>
          </div>
        <% end %>
      </div>
    </div>

    <div class="insight-class-details__desc<%= ' is-expanded' unless needs_toggle %>"<%= raw(' data-controller="description-toggle" data-description-toggle-expanded-value="false"') if desc.present? && needs_toggle %>>
      <h4 class="insight-card__subheading">Description</h4>
      <% if desc.present? %>
        <div class="insight-class-details__text<%= ' insight-class-details__text--clamp' if needs_toggle %>">
          <%= simple_format(desc) %>
        </div>
        <% if needs_toggle %>
          <button type="button" class="insight-class-details__read-more" data-description-toggle-target="button" data-action="description-toggle#toggle">Read more</button>
        <% end %>
      <% else %>
        <p class="insight-class-details__text insight-class-details__text--muted">—</p>
      <% end %>
    </div>
  </div>
</div>
