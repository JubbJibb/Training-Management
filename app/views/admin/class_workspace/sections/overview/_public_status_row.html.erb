<%
  tc = local_assigns[:training_class] || @training_class
  status = tc.class_status.presence || "private"
  badge_variant = { "public" => :info, "private" => :warning, "tentative" => :danger }.fetch(status, :neutral)
  status_label = status.capitalize
%>
<div id="workspace-overview-public-status" class="insight-progress-row insight-progress-row--status">
  <span class="insight-progress-row__label">Status</span>
  <span class="insight-progress-row__value">
    <div class="dropdown d-inline-block overview-status-dropdown">
      <button type="button" class="overview-status-toggle dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false" aria-label="Change class status" title="Public (Blue), Private (Yellow), Tentative (Red)">
        <%= odt_badge(status_label, variant: badge_variant, size: :sm) %>
        <i class="bi bi-chevron-down overview-status-dropdown__icon" aria-hidden="true"></i>
      </button>
      <ul class="dropdown-menu dropdown-menu-end">
        <li><%= link_to "Public", admin_class_workspace_public_path(tc, class_status: "public"), class: "dropdown-item #{'active' if status == 'public'}", data: { turbo_method: :patch, turbo_stream: true } %></li>
        <li><%= link_to "Private", admin_class_workspace_public_path(tc, class_status: "private"), class: "dropdown-item #{'active' if status == 'private'}", data: { turbo_method: :patch, turbo_stream: true } %></li>
        <li><%= link_to "Tentative", admin_class_workspace_public_path(tc, class_status: "tentative"), class: "dropdown-item #{'active' if status == 'tentative'}", data: { turbo_method: :patch, turbo_stream: true } %></li>
      </ul>
    </div>
  </span>
</div>
