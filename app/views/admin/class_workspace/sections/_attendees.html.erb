<%
  training_class = local_assigns[:training_class] || @training_class
  attendees = local_assigns[:attendees] || @attendees || []
  sort_column = local_assigns[:sort_column].presence || @sort_column.presence || "name"
  sort_direction = local_assigns[:sort_direction].presence || @sort_direction.presence || "asc"
  sort_params = request.query_parameters.slice("tab", "payment", "source", "q", "sort", "direction").compact
  return_to_url = request.original_url
  bulk_source_opts = attendee_source_channel_options
%>
<div class="workspace-section workspace-section--attendees attendees-ledger attendees-ledger--actionable">
  <div class="attendees-ledger__toolbar">
    <%= link_to new_admin_training_class_attendee_path(training_class, return_to: return_to_url), class: "odt-btn odt-btn--primary odt-btn--sm" do %>
      <i class="bi bi-person-plus" aria-hidden="true"></i> Add attendee
    <% end %>
    <div class="attendees-ledger__toolbar-actions">
      <%= link_to mailto_send_reminder_all_attendees(training_class, attendees), class: "odt-btn odt-btn--secondary odt-btn--sm", target: "_blank", rel: "noopener", title: "Open Outlook with all attendee emails" do %><i class="bi bi-send"></i> Send reminder<% end %>
      <button type="button" class="odt-btn odt-btn--secondary odt-btn--sm" data-toast="Export started (mock)"><i class="bi bi-download"></i> Export</button>
    </div>
  </div>

  <%= render "admin/class_workspace/sections/attendees_filter_bar", training_class: training_class %>

  <%= form_with url: bulk_update_admin_training_class_attendees_path(training_class), method: :post, local: true, html: { id: "ledger-bulk-form" } do %>
    <%= hidden_field_tag :return_to, request.original_fullpath, id: "ledger-bulk-return" %>
    <%= hidden_field_tag :bulk_action, "", id: "ledger-bulk-action" %>
    <%= hidden_field_tag :bulk_source, "", id: "ledger-bulk-source" %>
  <% end %>

  <div class="attendees-ledger__bulk-bar" id="ledger-bulk-bar" hidden>
    <span class="attendees-ledger__bulk-bar-text"><strong id="ledger-bulk-count">0</strong> selected</span>
    <div class="attendees-ledger__bulk-bar-actions">
      <button type="button" class="odt-btn odt-btn--secondary odt-btn--sm" data-bulk="mark_paid">Mark paid</button>
      <button type="button" class="odt-btn odt-btn--secondary odt-btn--sm" data-bulk="send_reminder">Send reminder</button>
      <div class="attendees-ledger__bulk-source">
        <label class="visually-hidden" for="ledger-bulk-source-pick">Source for bulk update</label>
        <select id="ledger-bulk-source-pick" class="form-select form-select-sm attendees-ledger__bulk-source-select" aria-label="Bulk source">
          <option value="">Source…</option>
          <% bulk_source_opts.each do |opt| %>
            <option value="<%= opt %>"><%= opt %></option>
          <% end %>
        </select>
        <button type="button" class="odt-btn odt-btn--primary odt-btn--sm" data-bulk="change_source">Set source</button>
      </div>
    </div>
  </div>

  <% if attendees.any? %>
    <div class="attendees-ledger__table-wrap">
      <table class="attendees-ledger__table" role="table" aria-label="Attendees">
        <thead>
          <tr>
            <th scope="col" class="attendees-ledger__th attendees-ledger__th--check">
              <input type="checkbox" class="form-check-input" id="ledger-select-all" aria-label="Select all rows in this list">
            </th>
            <th scope="col" class="attendees-ledger__th attendees-ledger__th--no">#No</th>
            <th scope="col" class="attendees-ledger__th attendees-ledger__th--name">
              <%= link_to admin_class_workspace_attendees_path(training_class, **sort_params.merge(sort: "name", direction: (sort_column == "name" && sort_direction == "asc" ? "desc" : "asc"))), class: "attendees-ledger__sort-link #{sort_column == "name" ? "attendees-ledger__sort-link--active" : ""}", data: { turbo_frame: "_top" } do %>
                Name / Email <%= sort_column == "name" ? (sort_direction == "asc" ? "↑" : "↓") : "" %>
              <% end %>
            </th>
            <th scope="col" class="attendees-ledger__th attendees-ledger__th--company">
              Company
            </th>
            <th scope="col" class="attendees-ledger__th attendees-ledger__th--type">
              <%= link_to admin_class_workspace_attendees_path(training_class, **sort_params.merge(sort: "participant_type", direction: (sort_column == "participant_type" && sort_direction == "asc" ? "desc" : "asc"))), class: "attendees-ledger__sort-link #{sort_column == "participant_type" ? "attendees-ledger__sort-link--active" : ""}", data: { turbo_frame: "_top" } do %>
                Type <%= sort_column == "participant_type" ? (sort_direction == "asc" ? "↑" : "↓") : "" %>
              <% end %>
            </th>
            <th scope="col" class="attendees-ledger__th attendees-ledger__th--seats">
              <%= link_to admin_class_workspace_attendees_path(training_class, **sort_params.merge(sort: "seats", direction: (sort_column == "seats" && sort_direction == "asc" ? "desc" : "asc"))), class: "attendees-ledger__sort-link #{sort_column == "seats" ? "attendees-ledger__sort-link--active" : ""}", data: { turbo_frame: "_top" } do %>
                Seats <%= sort_column == "seats" ? (sort_direction == "asc" ? "↑" : "↓") : "" %>
              <% end %>
            </th>
            <th scope="col" class="attendees-ledger__th attendees-ledger__th--source">
              <%= link_to admin_class_workspace_attendees_path(training_class, **sort_params.merge(sort: "source_channel", direction: (sort_column == "source_channel" && sort_direction == "asc" ? "desc" : "asc"))), class: "attendees-ledger__sort-link #{sort_column == "source_channel" ? "attendees-ledger__sort-link--active" : ""}", data: { turbo_frame: "_top" } do %>
                Source <%= sort_column == "source_channel" ? (sort_direction == "asc" ? "↑" : "↓") : "" %>
              <% end %>
            </th>
            <th scope="col" class="attendees-ledger__th attendees-ledger__th--payment">
              <%= link_to admin_class_workspace_attendees_path(training_class, **sort_params.merge(sort: "payment_status", direction: (sort_column == "payment_status" && sort_direction == "asc" ? "desc" : "asc"))), class: "attendees-ledger__sort-link #{sort_column == "payment_status" ? "attendees-ledger__sort-link--active" : ""}", data: { turbo_frame: "_top" } do %>
                Payment <%= sort_column == "payment_status" ? (sort_direction == "asc" ? "↑" : "↓") : "" %>
              <% end %>
            </th>
            <th scope="col" class="attendees-ledger__th attendees-ledger__th--amount">
              <%= link_to admin_class_workspace_attendees_path(training_class, **sort_params.merge(sort: "amount", direction: (sort_column == "amount" && sort_direction == "asc" ? "desc" : "asc"))), class: "attendees-ledger__sort-link #{sort_column == "amount" ? "attendees-ledger__sort-link--active" : ""}", data: { turbo_frame: "_top" } do %>
                Amount <%= sort_column == "amount" ? (sort_direction == "asc" ? "↑" : "↓") : "" %>
              <% end %>
            </th>
            <th scope="col" class="attendees-ledger__th attendees-ledger__th--actions"><span class="visually-hidden">Actions</span></th>
          </tr>
        </thead>
        <tbody>
          <% attendees.each_with_index do |a, idx| %>
            <%= render "admin/class_workspace/sections/ledger_attendee_row",
                training_class: training_class,
                attendee: a,
                row_index: idx + 1,
                sort_params: sort_params,
                return_to: return_to_url %>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <%= render "admin/class_workspace/shared/empty_state",
        icon: "people",
        title: "No attendees match",
        message: "Try changing filters or add an attendee.",
        action_label: "Add attendee",
        action_url: new_admin_training_class_attendee_path(training_class, return_to: return_to_url) %>
  <% end %>
</div>

<script>
(function() {
  var form = document.querySelector('#attendees-filter-bar .reg-filter-bar__form');
  if (form) {
    form.querySelectorAll('select[data-reg-filter-submit]').forEach(function(sel) {
      sel.addEventListener('change', function() { form.submit(); });
    });
  }

  var bar = document.getElementById('ledger-bulk-bar');
  var countEl = document.getElementById('ledger-bulk-count');
  var bulkForm = document.getElementById('ledger-bulk-form');
  var actionEl = document.getElementById('ledger-bulk-action');
  var sourceHidden = document.getElementById('ledger-bulk-source');
  var selectAll = document.getElementById('ledger-select-all');
  var sourcePick = document.getElementById('ledger-bulk-source-pick');
  if (!bar || !bulkForm || !actionEl) return;

  function allChecks() {
    return Array.prototype.slice.call(document.querySelectorAll('.ledger-row-check'));
  }

  function updateBulkBar() {
    var n = allChecks().filter(function(c) { return c.checked; }).length;
    countEl.textContent = String(n);
    bar.hidden = n === 0;
    if (selectAll) {
      var total = allChecks().length;
      selectAll.checked = total > 0 && n === total;
      selectAll.indeterminate = n > 0 && n < total;
    }
  }

  allChecks().forEach(function(c) {
    c.addEventListener('change', updateBulkBar);
  });

  if (selectAll) {
    selectAll.addEventListener('change', function() {
      allChecks().forEach(function(c) { c.checked = selectAll.checked; });
      updateBulkBar();
    });
  }

  document.querySelectorAll('[data-bulk]').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var n = allChecks().filter(function(c) { return c.checked; }).length;
      if (!n) return;
      var act = btn.getAttribute('data-bulk');
      actionEl.value = act;
      sourceHidden.value = '';
      if (act === 'change_source') {
        var src = sourcePick ? sourcePick.value : '';
        if (!src) {
          if (typeof window.showToast === 'function') window.showToast('Select a source first', 'warning');
          else alert('Select a source first');
          return;
        }
        sourceHidden.value = src;
      }
      bulkForm.submit();
    });
  });
})();
</script>
