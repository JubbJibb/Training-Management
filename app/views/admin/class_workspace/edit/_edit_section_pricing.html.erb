<%# Pricing: price/seat, cost; currency/VAT helper %>
<div class="odt-edit-card">
  <div class="odt-edit-card__strip"></div>
  <div class="odt-edit-card__body">
    <header class="odt-edit-card__header">
      <span class="odt-edit-card__title"><i class="bi bi-currency-exchange" aria-hidden="true"></i> Pricing</span>
    </header>
    <div class="odt-edit-card__content">
      <div class="odt-edit-fields odt-edit-fields--grid">
        <div class="odt-edit-field">
          <%= f.label :price, "Price per seat (THB)", class: "odt-edit-field__label" %>
          <%= f.number_field :price, class: "odt-edit-field__input", step: 0.01, min: 0, value: @training_class.price || 0, placeholder: "Selling price per person" %>
        </div>
        <div class="odt-edit-field">
          <%= f.label :cost, "Cost of class (THB)", class: "odt-edit-field__label" %>
          <%= f.number_field :cost, class: "odt-edit-field__input", step: 0.01, min: 0, value: @training_class.cost || 0, placeholder: "Class cost" %>
        </div>
      </div>
      <div class="odt-edit-field odt-edit-field--checkbox" style="margin-top: 0.75rem;">
        <%= f.check_box :vat_excluded, class: "odt-edit-field__checkbox" %>
        <%= f.label :vat_excluded, "VAT excluded for payment", class: "odt-edit-field__label odt-edit-field__label--inline" %>
      </div>
      <p class="odt-edit-field__helper odt-edit-field__helper--block">Prices in Thai Baht. When "VAT excluded" is checked, the payment amount is the price before VAT (no 7% added).</p>
    </div>
  </div>
</div>
