<%# Schedule: start/end date, start/end time, duration indicator %>
<div class="odt-edit-card">
  <div class="odt-edit-card__strip"></div>
  <div class="odt-edit-card__body">
    <header class="odt-edit-card__header">
      <span class="odt-edit-card__title"><i class="bi bi-calendar3" aria-hidden="true"></i> Schedule</span>
    </header>
    <div class="odt-edit-card__content">
      <div class="odt-edit-fields odt-edit-fields--grid">
        <div class="odt-edit-field">
          <%= f.label :date, "Start date", class: "odt-edit-field__label" %>
          <%= f.date_field :date, class: "odt-edit-field__input", required: true %>
        </div>
        <div class="odt-edit-field">
          <%= f.label :end_date, "End date (optional)", class: "odt-edit-field__label" %>
          <%= f.date_field :end_date, class: "odt-edit-field__input" %>
          <span class="odt-edit-field__helper">Leave blank for single day</span>
        </div>
      </div>
      <div class="odt-edit-fields odt-edit-fields--grid">
        <div class="odt-edit-field">
          <%= f.label :start_time, class: "odt-edit-field__label" %>
          <%= f.time_field :start_time, class: "odt-edit-field__input" %>
        </div>
        <div class="odt-edit-field">
          <%= f.label :end_time, class: "odt-edit-field__label" %>
          <%= f.time_field :end_time, class: "odt-edit-field__input" %>
        </div>
      </div>
      <div class="odt-edit-schedule-duration">
        <i class="bi bi-clock" aria-hidden="true"></i>
        <span>Duration: <strong><%= @training_class.duration %></strong></span>
        <span class="odt-edit-field__helper">(auto from dates)</span>
      </div>
    </div>
  </div>
</div>
