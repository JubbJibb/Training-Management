<%
  heatmap = local_assigns[:cohort_heatmap_data] || @data&.dig(:cohort_heatmap_data) || {}
  returning_pct = local_assigns[:returning_revenue_pct] || @data&.dig(:returning_revenue_pct) || 0
  row_labels = heatmap[:row_labels] || []
  col_labels = heatmap[:col_labels] || []
  cells = heatmap[:cells] || []
  kpi_badge = (returning_pct.is_a?(Numeric) || returning_pct.to_s.present?) ? { label: "รายได้จากลูกค้าเก่า:", value: "#{returning_pct}%" } : nil
  if kpi_badge && defined?(bi_tooltip_content)
    # Tooltip for returning revenue can go on the badge if needed
  end
%>
<%= render "shared/insight_card",
  title: "พฤติกรรมเรียนซ้ำ (Cohort)",
  subtitle: "% กลับมาเรียนตามเดือนหลังจ่ายครั้งแรก",
  title_tooltip: :cohort,
  kpi_badge: kpi_badge do %>
  <% if row_labels.any? && col_labels.any? %>
    <div class="insight-data-table-wrap">
      <table class="insight-data-table cohort-heatmap-table" role="table">
        <thead>
          <tr>
            <th scope="col" class="cohort-heatmap__th-row">
              <span class="bi-info-tooltip-trigger-wrap">Cohort<%= render "shared/bi_info_tooltip", **bi_tooltip_content(:cohort), placement: "top" %></span>
            </th>
            <% col_labels.each do |cl| %>
              <th scope="col" class="insight-data-table__th-num"><%= cl %></th>
            <% end %>
          </tr>
        </thead>
        <tbody>
          <% row_labels.each_with_index do |rl, ri| %>
            <tr>
              <td class="cohort-heatmap__td-label"><%= rl %></td>
              <% (cells[ri] || []).each do |pct| %>
                <td class="insight-data-table__num cohort-heatmap__td-cell" data-pct="<%= pct %>" style="--pct: <%= [pct, 100].min %>;"><%= pct %>%</td>
              <% end %>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <%= render "shared/empty_state", title: "ไม่มีข้อมูล cohort", icon: "grid-3x3", extra_class: "insight-card__empty" %>
  <% end %>
<% end %>
