<%
  top_channels = local_assigns[:top_channels] || []
  top_courses = local_assigns[:top_courses] || []
  top_spenders = local_assigns[:top_spenders] || []
  repeat_learners = local_assigns[:repeat_learners] || []
  active_tab = local_assigns[:active_tab].to_s.presence || "channels"
  # Map tab names to insight_dashboard topListView values
  view_map = { "channels" => "channel", "courses" => "course", "spenders" => "top_spender", "repeat" => "repeat" }
  active_value = view_map[active_tab] || "channel"
  tab_options = [
    { value: "channel", label: "ช่องทาง", target: "topListBtn" },
    { value: "course", label: "คอร์ส", target: "topListBtn" },
    { value: "top_spender", label: "จ่ายสูง", target: "topListBtn" },
    { value: "repeat", label: "เรียนซ้ำ", target: "topListBtn" }
  ]
  header_actions = render("shared/segmented_control",
    options: tab_options,
    active_value: active_value,
    group_name: "รายการ",
    value_param: "value",
    data_controller: "insight-dashboard",
    data_action: "click->insight-dashboard#changeTopListView"
  )
%>
<%= render "shared/insight_card",
  title: "Top lists",
  subtitle: "ช่องทาง · คอร์ส · จ่ายสูง · เรียนซ้ำ",
  header_actions: header_actions do %>
  <div class="insight-top-lists-panes">
    <div class="insight-top-lists-pane" id="top-list-channels" data-insight-dashboard-target="topListPane" data-pane="channel" <%= 'hidden' unless active_value == 'channel' %>>
      <% if top_channels.any? %>
        <%= render "shared/insight_data_table" do %>
          <thead>
            <tr>
              <th>ช่องทาง</th>
              <th class="insight-data-table__th-num">Leads</th>
              <th class="insight-data-table__th-num">ชำระ</th>
              <th class="insight-data-table__th-num">CVR</th>
            </tr>
          </thead>
          <tbody>
            <% top_channels.each do |r| %>
              <tr>
                <td><%= r[:channel].to_s.truncate(28) %></td>
                <td class="insight-data-table__num"><%= r[:leads] %></td>
                <td class="insight-data-table__num"><%= r[:paid] %></td>
                <td class="insight-data-table__num"><%= r[:cvr] %>%</td>
              </tr>
            <% end %>
          </tbody>
        <% end %>
      <% else %>
        <%= render "shared/empty_state", title: "ไม่มีข้อมูลช่องทาง", icon: "broadcast", extra_class: "insight-card__empty" %>
      <% end %>
    </div>
    <div class="insight-top-lists-pane" id="top-list-courses" data-insight-dashboard-target="topListPane" data-pane="course" <%= 'hidden' unless active_value == 'course' %>>
      <% if top_courses.any? %>
        <%= render "shared/insight_data_table" do %>
          <thead>
            <tr>
              <th>คอร์ส</th>
              <th class="insight-data-table__th-num">รายได้</th>
              <th class="insight-data-table__th-num">ชำระ</th>
              <th class="insight-data-table__th-num">CVR</th>
            </tr>
          </thead>
          <tbody>
            <% top_courses.each do |r| %>
              <tr>
                <td><%= r[:course].to_s.truncate(32) %></td>
                <td class="insight-data-table__num"><%= number_to_thb(r[:revenue]) %></td>
                <td class="insight-data-table__num"><%= r[:paid_count] %></td>
                <td class="insight-data-table__num"><%= r[:cvr] %>%</td>
              </tr>
            <% end %>
          </tbody>
        <% end %>
      <% else %>
        <%= render "shared/empty_state", title: "ไม่มีข้อมูลคอร์ส", icon: "journal-bookmark", extra_class: "insight-card__empty" %>
      <% end %>
    </div>
    <div class="insight-top-lists-pane" id="top-list-spenders" data-insight-dashboard-target="topListPane" data-pane="top_spender" <%= 'hidden' unless active_value == 'top_spender' %>>
      <% if top_spenders.any? %>
        <%= render "shared/insight_data_table" do %>
          <thead>
            <tr>
              <th>ลูกค้า</th>
              <th class="insight-data-table__th-num">รวมจ่าย</th>
              <th class="insight-data-table__th-num">จำนวนคลาส</th>
              <th>กิจกรรมล่าสุด</th>
            </tr>
          </thead>
          <tbody>
            <% top_spenders.each do |r| %>
              <tr>
                <td><%= r[:customer].to_s.truncate(24) %></td>
                <td class="insight-data-table__num"><%= number_to_thb(r[:total_paid]) %></td>
                <td class="insight-data-table__num"><%= r[:classes_attended] %></td>
                <td><%= r[:last_activity].respond_to?(:strftime) ? r[:last_activity].strftime("%Y-%m-%d") : (r[:last_activity].to_s.presence || "—") %></td>
              </tr>
            <% end %>
          </tbody>
        <% end %>
      <% else %>
        <%= render "shared/empty_state", title: "ไม่มีข้อมูลลูกค้าจ่ายสูง", icon: "currency-dollar", extra_class: "insight-card__empty" %>
      <% end %>
    </div>
    <div class="insight-top-lists-pane" id="top-list-repeat" data-insight-dashboard-target="topListPane" data-pane="repeat" <%= 'hidden' unless active_value == 'repeat' %>>
      <% if repeat_learners.any? %>
        <%= render "shared/insight_data_table" do %>
          <thead>
            <tr>
              <th>ลูกค้า</th>
              <th class="insight-data-table__th-num">จำนวนคลาส</th>
              <th class="insight-data-table__th-num">อัตราซ้ำ</th>
              <th>คอร์สที่ชอบ</th>
            </tr>
          </thead>
          <tbody>
            <% repeat_learners.each do |r| %>
              <tr>
                <td><%= r[:customer].to_s.truncate(24) %></td>
                <td class="insight-data-table__num"><%= r[:num_classes] %></td>
                <td class="insight-data-table__num"><%= r[:repeat_rate] %>%</td>
                <td><%= r[:favorite_course].to_s.truncate(28) %></td>
              </tr>
            <% end %>
          </tbody>
        <% end %>
      <% else %>
        <%= render "shared/empty_state", title: "ไม่มีข้อมูลผู้เรียนซ้ำ", icon: "arrow-repeat", extra_class: "insight-card__empty" %>
      <% end %>
    </div>
  </div>
<% end %>
