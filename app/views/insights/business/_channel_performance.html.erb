<%
  perf = local_assigns[:channel_performance] || @data&.dig(:channel_performance) || {}
  rows = perf[:rows] || []
  sort_by = perf[:sort_by].to_s.presence || "revenue"
  total_rev = rows.sum { |r| (r[:revenue] || 0).to_f }
  cvr_varied = rows.any? && rows.map { |r| (r[:cvr] || 0).to_f }.uniq.size > 1
  sort_options = [
    { value: "revenue", label: "รายได้", target: "sortBtn" },
    { value: "paid", label: "จำนวนชำระ", target: "sortBtn" }
  ]
  header_actions = render("shared/segmented_control",
    options: sort_options,
    active_value: sort_by,
    group_name: "เรียงตาม",
    value_param: "sort",
    data_controller: "insight-dashboard",
    data_action: "click->insight-dashboard#changeSort"
  )
%>
<%= render "shared/insight_card",
  title: "ประสิทธิภาพช่องทาง",
  subtitle: "เรียงตามรายได้ / จำนวนชำระ",
  header_actions: header_actions do %>
  <% if rows.any? %>
    <%= turbo_frame_tag "channel_performance", class: "insight-data-table-wrap" do %>
      <%= render "shared/insight_data_table" do %>
        <thead>
          <tr>
            <th scope="col">ช่องทาง</th>
            <th scope="col" class="insight-data-table__th-num">
              <span class="bi-info-tooltip-trigger-wrap">Leads<%= render "shared/bi_info_tooltip", **bi_tooltip_content(:leads), placement: "top" %></span>
            </th>
            <th scope="col" class="insight-data-table__th-num">ชำระ</th>
            <th scope="col" class="insight-data-table__th-num">
              <span class="bi-info-tooltip-trigger-wrap">รายได้<%= render "shared/bi_info_tooltip", **bi_tooltip_content(:revenue_header), placement: "top" %></span>
            </th>
            <th scope="col" class="insight-data-table__th-num">
              <span class="bi-info-tooltip-trigger-wrap">เฉลี่ย ฿/คน<%= render "shared/bi_info_tooltip", **bi_tooltip_content(:avg_head_header), placement: "top" %></span>
            </th>
            <% if cvr_varied %>
              <th scope="col" class="insight-data-table__th-num">
                <span class="bi-info-tooltip-trigger-wrap">CVR<%= render "shared/bi_info_tooltip", **bi_tooltip_content(:cvr_header), placement: "top" %></span>
              </th>
            <% end %>
            <th scope="col" class="insight-data-table__th-num">สัดส่วนรายได้</th>
          </tr>
        </thead>
        <tbody>
          <% rows.sort_by { |h| sort_by == "paid" ? -h[:paid].to_i : -h[:revenue].to_f }.each do |r| %>
            <%
              ch = (r[:channel].to_s.presence || "อื่นๆ")
              rev = (r[:revenue] || 0).to_f
              share_pct = total_rev.positive? ? (rev / total_rev * 100) : 0
            %>
            <tr data-channel-id="<%= ch.to_s.gsub('"', '&quot;') %>"
                data-insight-dashboard-target="perfRow"
                data-revenue="<%= rev %>"
                data-paid="<%= r[:paid].to_i %>"
                data-action="click->insight-dashboard#selectChannel keydown.enter->insight-dashboard#selectChannel"
                role="button"
                tabindex="0"
                aria-label="ดูช่องทาง <%= ch %>"
                class="insight-data-table__row">
              <td><%= ch.to_s.truncate(24) %></td>
              <td class="insight-data-table__num"><%= r[:leads] %></td>
              <td class="insight-data-table__num"><%= r[:paid] %></td>
              <td class="insight-data-table__num">
                <span class="insight-data-table__revenue-main"><%= number_to_thb(rev) %></span>
                <span class="insight-data-table__revenue-sub"><%= number_to_percentage(share_pct, precision: 1) %></span>
              </td>
              <td class="insight-data-table__num"><%= number_to_thb(r[:avg_price_head]) %></td>
              <% if cvr_varied %>
                <td class="insight-data-table__num"><%= r[:cvr] %>%</td>
              <% end %>
              <td class="insight-data-table__num"><%= number_to_percentage(share_pct, precision: 1) %></td>
            </tr>
          <% end %>
        </tbody>
      <% end %>
    <% end %>
  <% else %>
    <%= render "shared/empty_state", title: "ไม่มีข้อมูลช่องทาง", icon: "broadcast", extra_class: "insight-card__empty" %>
  <% end %>
<% end %>
