<%
  perf = local_assigns[:channel_performance] || @data&.dig(:channel_performance) || {}
  rows = perf[:rows] || []
  sort_by = perf[:sort_by].to_s.presence || "revenue"
%>
<div class="insight-card">
  <div class="insight-card__header">
    <div class="insight-card__accent"></div>
    <div class="insight-card__head-text">
      <h3 class="insight-card__title">ประสิทธิภาพช่องทาง</h3>
      <p class="insight-card__subtitle">เรียงตามรายได้ / จำนวนชำระ</p>
    </div>
    <div class="insight-card__header-actions">
      <div class="bi-sort-toggle" role="group" aria-label="เรียงตาม">
        <span class="bi-sort-toggle__label">เรียงตาม:</span>
        <button type="button" class="bi-sort-btn <%= 'bi-sort-btn--active' if sort_by == 'revenue' %>" data-sort="revenue">รายได้</button>
        <button type="button" class="bi-sort-btn <%= 'bi-sort-btn--active' if sort_by == 'paid' %>" data-sort="paid">จำนวนชำระ</button>
      </div>
    </div>
  </div>
  <div class="insight-card__body">
    <% if rows.any? %>
      <div class="bi-table-wrap">
        <table class="bi-table bi-channel-perf-table" role="table">
          <thead>
            <tr>
              <th scope="col">ช่องทาง</th>
              <th scope="col" class="text-end">
                <span class="bi-info-tooltip-trigger-wrap">Leads<%= render "shared/bi_info_tooltip", **bi_tooltip_content(:leads), placement: "top" %></span>
              </th>
              <th scope="col" class="text-end">ชำระ</th>
              <th scope="col" class="text-end">
                <span class="bi-info-tooltip-trigger-wrap">รายได้<%= render "shared/bi_info_tooltip", **bi_tooltip_content(:revenue_header), placement: "top" %></span>
              </th>
              <th scope="col" class="text-end">
                <span class="bi-info-tooltip-trigger-wrap">เฉลี่ย ฿/คน<%= render "shared/bi_info_tooltip", **bi_tooltip_content(:avg_head_header), placement: "top" %></span>
              </th>
              <th scope="col" class="text-end">
                <span class="bi-info-tooltip-trigger-wrap">CVR<%= render "shared/bi_info_tooltip", **bi_tooltip_content(:cvr_header), placement: "top" %></span>
              </th>
            </tr>
          </thead>
          <tbody>
            <% rows.sort_by { |h| sort_by == "paid" ? -h[:paid] : -h[:revenue] }.each do |r| %>
              <tr data-revenue="<%= r[:revenue] %>" data-paid="<%= r[:paid] %>">
                <td><%= r[:channel].to_s.truncate(24) %></td>
                <td class="text-end"><%= r[:leads] %></td>
                <td class="text-end"><%= r[:paid] %></td>
                <td class="text-end"><%= number_to_thb(r[:revenue]) %></td>
                <td class="text-end"><%= number_to_thb(r[:avg_price_head]) %></td>
                <td class="text-end"><%= r[:cvr] %>%</td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <%= render "shared/empty_state", title: "ไม่มีข้อมูลช่องทาง", icon: "broadcast", extra_class: "bi-empty" %>
    <% end %>
  </div>
</div>
<script>
(function() {
  var card = document.querySelector('.bi-channel-perf-table');
  if (!card) return;
  var tbody = card.querySelector('tbody');
  var btns = card.closest('.insight-card').querySelectorAll('.bi-sort-btn');
  if (!tbody || !btns.length) return;
  btns.forEach(function(btn) {
    btn.addEventListener('click', function() {
      var sort = this.getAttribute('data-sort');
      btns.forEach(function(b) { b.classList.remove('bi-sort-btn--active'); });
      this.classList.add('bi-sort-btn--active');
      var rows = Array.from(tbody.querySelectorAll('tr'));
      rows.sort(function(a, b) {
        var va = parseFloat(a.getAttribute('data-' + sort)) || 0;
        var vb = parseFloat(b.getAttribute('data-' + sort)) || 0;
        return vb - va;
      });
      rows.forEach(function(r) { tbody.appendChild(r); });
    });
  });
})();
</script>
