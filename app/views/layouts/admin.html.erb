<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Admin - Training Management" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <script src="https://code.iconify.design/3/3.1.1/iconify.min.js" defer></script>
    <%= stylesheet_link_tag "design_tokens", "design_system", "odt_cards", "odt_dashboard", "application", "admin/class_edit", "nav_dropdown", "financials_nav_dropdown", "financials_shared", "training_calendar", "data-turbo-track": "reload" %>
    <%= render "shared/apex_chart_turbo_init" %>
  </head>

  <body class="admin-layout-body">
    <nav class="navbar" role="navigation">
      <div class="nav-container">
        <div class="nav-left">
          <%= link_to operations_training_calendar_path, class: "nav-logo-link" do %>
            <%= image_tag "odt_logo.svg", alt: "ODT", class: "nav-logo" %>
          <% end %>
        </div>
        <button type="button" class="nav-toggle" aria-label="Toggle menu" aria-expanded="false" aria-controls="nav-menu" data-nav-toggle>
          <span class="nav-toggle__bar"></span>
          <span class="nav-toggle__bar"></span>
          <span class="nav-toggle__bar"></span>
        </button>
        <%= render "shared/main_nav" %>
      </div>
    </nav>

    <div class="admin-layout-main">
      <% if notice %>
        <div class="alert alert-success alert-dismissible fade show" role="alert">
          <%= notice %>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% end %>

      <% if alert %>
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
          <%= alert %>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% end %>

      <%= yield %>
    </div>

    <div id="floating-ui-root" aria-live="polite"></div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <%= javascript_importmap_tags %>
    <%= render "shared/table_sort_filter_script" %>
    <%= render "shared/portal_dropdown_script" %>
    <script>
      (function() {
        if (window.__navHandlersBound) return;
        window.__navHandlersBound = true;
          document.addEventListener('click', function(e) {
            var toggle = e.target.closest('[data-nav-dropdown]');
            var inDropdown = e.target.closest('.navbar .nav-dropdown');
            if (toggle) {
              e.preventDefault();
              e.stopPropagation();
              var parent = toggle.closest('.nav-dropdown');
              var menu = parent && parent.querySelector('.dropdown-menu');
              var isOpen = parent && parent.classList.contains('show');
              document.querySelectorAll('.navbar .nav-dropdown.show').forEach(function(d) {
                if (d !== parent) {
                  d.classList.remove('show');
                  var m = d.querySelector('.dropdown-menu');
                  if (m) m.classList.remove('show');
                  var t = d.querySelector('[data-nav-dropdown]');
                  if (t) t.setAttribute('aria-expanded', 'false');
                }
              });
              if (parent && menu) {
                if (isOpen) {
                  parent.classList.remove('show');
                  menu.classList.remove('show');
                  toggle.setAttribute('aria-expanded', 'false');
                } else {
                  parent.classList.add('show');
                  menu.classList.add('show');
                  toggle.setAttribute('aria-expanded', 'true');
                }
              }
            } else if (!inDropdown) {
              document.querySelectorAll('.navbar .nav-dropdown.show').forEach(function(d) {
                d.classList.remove('show');
                var m = d.querySelector('.dropdown-menu');
                if (m) m.classList.remove('show');
                var t = d.querySelector('[data-nav-dropdown]');
                if (t) t.setAttribute('aria-expanded', 'false');
              });
            }
          });
        document.addEventListener('keydown', function(e) {
          if (e.key === 'Escape') {
            document.querySelectorAll('.navbar .nav-dropdown.show').forEach(function(d) {
              d.classList.remove('show');
              var m = d.querySelector('.dropdown-menu');
              if (m) m.classList.remove('show');
              var t = d.querySelector('[data-nav-dropdown]');
              if (t) t.setAttribute('aria-expanded', 'false');
            });
          }
        });
        document.addEventListener('click', function(e) {
          var btn = e.target.closest('[data-nav-toggle]');
          if (btn) {
            var menu = document.getElementById('nav-menu');
            if (menu) {
              var open = menu.classList.toggle('is-open');
              btn.setAttribute('aria-expanded', open);
            }
          }
        });

      })();
    </script>
    <%= yield :footer_scripts if content_for?(:footer_scripts) %>
  </body>
</html>
