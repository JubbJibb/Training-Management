<div class="tc-index-filter-box">
  <%= form_with url: financials_accounts_receivable_path, method: :get, data: { turbo_frame: "financials_ar" }, class: "tc-index-filter-bar__form" do %>
    <div class="tc-index-filter-bar__row">
      <div class="tc-index-filter-bar__field">
        <label for="financials_ar_period" class="tc-index-filter-bar__label">Period</label>
        <select name="period" id="financials_ar_period" class="tc-index-filter-bar__input">
          <option value="mtd" <%= "selected" if params[:period] == "mtd" %>>MTD</option>
          <option value="qtd" <%= "selected" if params[:period] == "qtd" %>>QTD</option>
          <option value="ytd" <%= "selected" if params[:period] == "ytd" %>>YTD</option>
          <option value="custom" <%= "selected" if params[:period] == "custom" %>>Custom</option>
        </select>
      </div>
      <div class="tc-index-filter-bar__field">
        <label for="financials_ar_date_from" class="tc-index-filter-bar__label">Start</label>
        <input type="date" name="date_from" id="financials_ar_date_from" class="tc-index-filter-bar__input" value="<%= params[:date_from] %>">
      </div>
      <div class="tc-index-filter-bar__field">
        <label for="financials_ar_date_to" class="tc-index-filter-bar__label">End</label>
        <input type="date" name="date_to" id="financials_ar_date_to" class="tc-index-filter-bar__input" value="<%= params[:date_to] %>">
      </div>
      <div class="tc-index-filter-bar__field">
        <label for="financials_ar_client_type" class="tc-index-filter-bar__label">Client type</label>
        <select name="client_type" id="financials_ar_client_type" class="tc-index-filter-bar__input">
          <option value="">All</option>
          <option value="Indi" <%= "selected" if params[:client_type] == "Indi" %>>Individual</option>
          <option value="Corp" <%= "selected" if params[:client_type] == "Corp" %>>Corporate</option>
        </select>
      </div>
      <div class="tc-index-filter-bar__field tc-index-filter-bar__field--checkbox">
        <label class="tc-index-filter-bar__label">&nbsp;</label>
        <label class="tc-index-filter-bar__checkbox-label">
          <input type="checkbox" name="overdue_only" value="1" <%= "checked" if params[:overdue_only] == "1" %> class="tc-index-filter-bar__input"> Overdue only
        </label>
      </div>
      <div class="tc-index-filter-bar__actions">
        <button type="submit" class="tc-index-filter-bar__btn tc-index-filter-bar__btn--primary">Apply</button>
        <%= link_to "Clear", financials_accounts_receivable_path, class: "tc-index-filter-bar__btn tc-index-filter-bar__btn--secondary", data: { turbo_frame: "financials_ar" } %>
      </div>
    </div>
  <% end %>
</div>
