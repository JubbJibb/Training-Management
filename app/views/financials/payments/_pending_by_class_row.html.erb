<%
  group = local_assigns[:group]
  tc = group[:training_class]
  base_params = local_assigns[:base_params] || {}
  priority = payment_priority_level(group)
  due_label = payment_due_label(group)
  display_amount = group[:total_amount].to_f
  unpaid_path = financials_payments_path(base_params.merge(class_id: tc.id))
  top_payers = group[:attendees].first(3)
  amt = ->(a) { (a.total_amount.to_f).positive? ? a.total_amount : (a.total_final_price || 0).to_f }
  last_reminder = last_reminder_sent_at(group[:attendees].map(&:id))
  row_id = "pt-pfc-row-#{tc.id}"
%>
<div class="pt-pfc-row" id="<%= row_id %>" data-pt-pfc-row data-priority="<%= priority %>">
  <div class="pt-pfc-row__main" role="button" tabindex="0" data-pt-pfc-toggle aria-expanded="false" aria-controls="<%= row_id %>-detail">
    <div class="pt-pfc-row__head">
      <span class="pt-pfc-row__badges">
        <% if priority != :none %>
          <span class="pt-pfc-row__badge pt-pfc-row__badge--<%= priority %>"><%= priority == :high ? 'HIGH' : (priority == :medium ? 'MEDIUM' : 'LOW') %></span>
        <% else %>
          <span class="pt-pfc-row__badge pt-pfc-row__badge--none">NO PAYMENT</span>
        <% end %>
        <span class="pt-pfc-row__due pt-pfc-row__due--<%= priority %>"><%= due_label %></span>
      </span>
      <span class="pt-pfc-row__expand" aria-hidden="true"><i class="bi bi-chevron-down"></i></span>
    </div>
    <div class="pt-pfc-row__body">
      <div class="pt-pfc-row__primary">
        <span class="pt-pfc-row__title"><%= group[:class_title] %></span>
        <span class="pt-pfc-row__amount <%= 'pt-pfc-row__amount--muted' if priority == :none %>"><%= number_to_thb(display_amount) %></span>
      </div>
      <div class="pt-pfc-row__meta">
        <span class="pt-pfc-row__count"><%= group[:count] %> unpaid</span>
        <span class="pt-pfc-row__sep">·</span>
        <span class="pt-pfc-row__date"><%= group[:class_date]&.strftime("%Y-%m-%d") %></span>
      </div>
      <% if top_payers.any? %>
        <p class="pt-pfc-row__payers">
          <%= top_payers.map { |a| (a.billing_name.presence || a.name).to_s.truncate(24) }.join(", ") %>
        </p>
      <% end %>
    </div>
    <div class="pt-pfc-row__actions">
      <%= link_to "Open class", admin_class_workspace_path(tc), class: "pt-pfc-row__btn pt-pfc-row__btn--primary", data: { turbo_frame: "_top" } %>
      <%= link_to "Unpaid list", unpaid_path, class: "pt-pfc-row__btn pt-pfc-row__btn--secondary", data: { turbo_frame: "financials_payments_workspace" } %>
      <button type="button" class="pt-pfc-row__btn pt-pfc-row__btn--expand" data-pt-pfc-toggle aria-label="Expand details"><i class="bi bi-chevron-down" aria-hidden="true"></i> Expand</button>
    </div>
  </div>

  <div class="pt-pfc-row__detail" id="<%= row_id %>-detail" hidden>
    <div class="pt-pfc-detail">
      <div class="pt-pfc-detail__block">
        <h4 class="pt-pfc-detail__heading">Pending details</h4>
        <ul class="pt-pfc-detail__list">
          <% group[:attendees].each do |a| %>
            <li class="pt-pfc-detail__list-item">
              <%= link_to financials_payment_path(a), class: "pt-pfc-detail__link", data: { turbo_frame: "_top" } do %>
                <span class="pt-pfc-detail__name"><%= (a.billing_name.presence || a.name).to_s.truncate(40) %></span>
                <span class="pt-pfc-detail__amt"><%= number_to_thb(amt.call(a)) %></span>
              <% end %>
              <%= link_to "View", financials_payment_path(a), class: "pt-pfc-detail__view", data: { turbo_frame: "_top" } %>
            </li>
          <% end %>
        </ul>
      </div>
      <div class="pt-pfc-detail__block">
        <h4 class="pt-pfc-detail__heading">Follow-up</h4>
        <dl class="pt-pfc-detail__meta">
          <dt>Last reminder sent</dt>
          <dd><%= last_reminder ? last_reminder.strftime("%d %b %Y %H:%M") : "—" %></dd>
          <dt>Payment status</dt>
          <dd>Pending</dd>
          <dt>Note / next action</dt>
          <dd class="pt-pfc-detail__note">—</dd>
        </dl>
      </div>
      <div class="pt-pfc-detail__actions">
        <%= link_to "Send reminder", unpaid_path, class: "pt-pfc-detail__btn pt-pfc-detail__btn--primary", data: { turbo_frame: "financials_payments_workspace" } %>
        <button type="button" class="pt-pfc-detail__btn pt-pfc-detail__btn--secondary" disabled>Mark as followed up</button>
        <%= link_to "Open class details", admin_class_workspace_path(tc), class: "pt-pfc-detail__btn pt-pfc-detail__btn--secondary", data: { turbo_frame: "_top" } %>
      </div>
    </div>
  </div>
</div>
