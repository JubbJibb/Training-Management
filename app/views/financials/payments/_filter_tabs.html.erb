<%
  summary = local_assigns[:summary] || {}
  current_status = params[:workflow_status]
  completed_today = params[:completed_today] == "1"
  base_params = params.permit(:period, :date_from, :date_to, :client_type, :class_id, :instructor, :overdue_only, :has_slip).to_h
  all_count = summary[:all_count] || 0
%>
<nav class="pi-tabs" role="tablist" aria-label="Payment queue filters">
  <%= link_to financials_payments_path(base_params), data: { turbo_frame: "financials_payments_workspace" }, class: "pi-tabs__tab #{current_status.blank? && !completed_today ? 'pi-tabs__tab--active' : ''}" do %>
    <span class="pi-tabs__label">All</span>
    <span class="pi-tabs__badge"><%= all_count %></span>
  <% end %>
  <%= link_to financials_payments_path(base_params.merge(workflow_status: "awaiting_verification")), data: { turbo_frame: "financials_payments_workspace" }, class: "pi-tabs__tab pi-tabs__tab--awaiting #{current_status == 'awaiting_verification' ? 'pi-tabs__tab--active' : ''}" do %>
    <span class="pi-tabs__label">Awaiting verification</span>
    <span class="pi-tabs__badge"><%= summary.dig(:awaiting_verification, :count) || 0 %></span>
  <% end %>
  <%= link_to financials_payments_path(base_params.merge(workflow_status: "overdue")), data: { turbo_frame: "financials_payments_workspace" }, class: "pi-tabs__tab pi-tabs__tab--overdue #{current_status == 'overdue' ? 'pi-tabs__tab--active' : ''}" do %>
    <span class="pi-tabs__label">Overdue</span>
    <span class="pi-tabs__badge"><%= summary.dig(:overdue, :count) || 0 %></span>
  <% end %>
  <%= link_to financials_payments_path(base_params.merge(workflow_status: "ready_send")), data: { turbo_frame: "financials_payments_workspace" }, class: "pi-tabs__tab pi-tabs__tab--ready #{current_status == 'ready_send' ? 'pi-tabs__tab--active' : ''}" do %>
    <span class="pi-tabs__label">Ready to send</span>
    <span class="pi-tabs__badge"><%= summary.dig(:ready_send, :count) || 0 %></span>
  <% end %>
  <%= link_to financials_payments_path(base_params.merge(completed_today: "1")), data: { turbo_frame: "financials_payments_workspace" }, class: "pi-tabs__tab pi-tabs__tab--completed #{completed_today ? 'pi-tabs__tab--active' : ''}" do %>
    <span class="pi-tabs__label">Completed today</span>
    <span class="pi-tabs__badge"><%= summary[:completed_today] || 0 %></span>
  <% end %>
</nav>
