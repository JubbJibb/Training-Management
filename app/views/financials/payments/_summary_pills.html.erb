<%
  summary = local_assigns[:summary] || {}
  current_status = params[:workflow_status]
  completed_today = params[:completed_today] == "1"
  base_params = params.permit(:period, :date_from, :date_to, :client_type, :class_id, :instructor, :overdue_only, :has_slip).to_h
  all_count = summary[:all_count] || 0
%>
<nav class="pt-summary-pills" role="navigation" aria-label="Payment status filters">
  <%= link_to financials_payments_path(base_params), data: { turbo_frame: "financials_payments_workspace" }, class: "pt-summary-pills__pill #{current_status.blank? && !completed_today ? 'pt-summary-pills__pill--active' : ''}" do %>
    <span class="pt-summary-pills__num"><%= all_count %></span>
    <span class="pt-summary-pills__label">All</span>
  <% end %>
  <%= link_to financials_payments_path(base_params.merge(workflow_status: "pending")), data: { turbo_frame: "financials_payments_workspace" }, class: "pt-summary-pills__pill #{current_status == 'pending' ? 'pt-summary-pills__pill--active' : ''}" do %>
    <span class="pt-summary-pills__num"><%= summary.dig(:pending, :count) || 0 %></span>
    <span class="pt-summary-pills__label">Pending</span>
  <% end %>
  <%= link_to financials_payments_path(base_params.merge(workflow_status: "awaiting_verification")), data: { turbo_frame: "financials_payments_workspace" }, class: "pt-summary-pills__pill #{current_status == 'awaiting_verification' ? 'pt-summary-pills__pill--active' : ''}" do %>
    <span class="pt-summary-pills__num"><%= summary.dig(:awaiting_verification, :count) || 0 %></span>
    <span class="pt-summary-pills__label">Awaiting verification</span>
  <% end %>
  <%= link_to financials_payments_path(base_params.merge(workflow_status: "overdue")), data: { turbo_frame: "financials_payments_workspace" }, class: "pt-summary-pills__pill #{current_status == 'overdue' ? 'pt-summary-pills__pill--active' : ''}" do %>
    <span class="pt-summary-pills__num"><%= summary.dig(:overdue, :count) || 0 %></span>
    <span class="pt-summary-pills__label">Overdue</span>
  <% end %>
  <%= link_to financials_payments_path(base_params.merge(workflow_status: "ready_send")), data: { turbo_frame: "financials_payments_workspace" }, class: "pt-summary-pills__pill #{current_status == 'ready_send' ? 'pt-summary-pills__pill--active' : ''}" do %>
    <span class="pt-summary-pills__num"><%= summary.dig(:ready_send, :count) || 0 %></span>
    <span class="pt-summary-pills__label">Ready to send</span>
  <% end %>
  <%= link_to financials_payments_path(base_params.merge(completed_today: "1")), data: { turbo_frame: "financials_payments_workspace" }, class: "pt-summary-pills__pill #{completed_today ? 'pt-summary-pills__pill--active' : ''}" do %>
    <span class="pt-summary-pills__num"><%= summary[:completed_today] || 0 %></span>
    <span class="pt-summary-pills__label">Completed today</span>
  <% end %>
</nav>
