<%
  top_overdue = local_assigns[:top_overdue] || @top_overdue || []
  ar_path = financials_accounts_receivable_path(params.permit(:period, :date_from, :date_to, :client_type))
%>
<%= turbo_frame_tag "financials_overview_top_overdue" do %>
  <div class="insight-card">
    <div class="insight-card__header">
      <div class="insight-card__accent"></div>
      <div class="insight-card__head-text">
        <h3 class="insight-card__title">Top overdue receivables</h3>
        <p class="insight-card__subtitle">Top 5</p>
      </div>
    </div>
    <div class="insight-card__body">
      <% if top_overdue.any? %>
        <table class="insight-odt-table" role="table">
          <thead>
            <tr>
              <th scope="col">Client</th>
              <th scope="col" class="text-end">Amount</th>
              <th scope="col">Age</th>
              <th scope="col" class="text-end"></th>
            </tr>
          </thead>
          <tbody>
            <% top_overdue.each do |row| %>
              <tr>
                <td class="insight-odt-table__truncate"><%= row[:client_name].to_s.truncate(40) %></td>
                <td class="text-end"><%= number_to_thb(row[:amount]) %></td>
                <td><%= row[:bucket_label] %></td>
                <td class="text-end">
                  <%= link_to "View", row[:link_path], class: "odt-btn odt-btn--ghost odt-btn--sm", data: { turbo_frame: "_top" } %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
        <%= link_to "Go to AR", ar_path, class: "odt-btn odt-btn--ghost odt-btn--sm mt-2", data: { turbo_frame: "_top" } %>
      <% else %>
        <p class="text-muted mb-0"><i class="bi bi-check-circle text-success" aria-hidden="true"></i> No overdue receivables.</p>
      <% end %>
    </div>
  </div>
<% end %>
