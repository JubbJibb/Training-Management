<%
  # Executive IA: Operations | Insights | Clients | Financials | Strategy | Settings
  # All submenus: same structure (click to open), same size, icon in front of each item.
  # Icons: Flowbite via Iconify — https://flowbite.com/icons/ / https://icon-sets.iconify.design/flowbite/
%>
<div class="nav-right" id="nav-menu">
  <%# Operations %>
  <div class="nav-dropdown <%= nav_active?("operations") %>">
    <button type="button" class="nav-link nav-link--dropdown nav-dropdown__toggle" id="navOperations" data-nav-dropdown aria-expanded="false" title="Manage program delivery and enrollment">
      <%= flowbite_icon("calendar-week-outline") %> Operations
    </button>
    <ul class="dropdown-menu dropdown-menu-end nav-dropdown__menu" aria-labelledby="navOperations">
      <li><%= link_to operations_training_calendar_path, class: "dropdown-item #{'active' if request.path == operations_training_calendar_path}" do %><%= flowbite_icon("calendar-week-outline", class: "dropdown-item-icon") %> Training Calendar<% end %></li>
      <li><%= link_to operations_training_classes_path, class: "dropdown-item" do %><%= flowbite_icon("file-lines-outline", class: "dropdown-item-icon") %> Training Classes<% end %></li>
      <li><%= link_to operations_courses_path, class: "dropdown-item" do %><%= flowbite_icon("book-open-outline", class: "dropdown-item-icon") %> Courses<% end %></li>
      <li><%= link_to operations_instructors_path, class: "dropdown-item" do %><%= flowbite_icon("user-circle-outline", class: "dropdown-item-icon") %> Instructors<% end %></li>
    </ul>
  </div>

  <%# Insights — System of Insight: read-only dashboards + cross-module priorities %>
  <div class="nav-dropdown <%= nav_active?("insights") %>">
    <button type="button" class="nav-link nav-link--dropdown nav-dropdown__toggle" id="navInsights" data-nav-dropdown aria-expanded="false" aria-controls="navInsightsMenu" title="Executive overview and cross-module priorities">
      <%= flowbite_icon("chart-outline") %> Insights
    </button>
    <ul class="dropdown-menu dropdown-menu-end nav-dropdown__menu" id="navInsightsMenu" aria-labelledby="navInsights" role="menu">
      <li role="none">
        <%= link_to insights_business_path, class: "dropdown-item #{insights_nav_item_active?(insights_business_path)}", role: "menuitem" do %><%= flowbite_icon("chart-line-outline", class: "dropdown-item-icon") %> Business Insights<% end %>
      </li>
      <li role="none">
        <%= link_to insights_actions_path, class: "dropdown-item #{insights_nav_item_active?(insights_actions_path)}", role: "menuitem" do %><%= flowbite_icon("clipboard-document-list-outline", class: "dropdown-item-icon") %> Action Center<% end %>
      </li>
    </ul>
  </div>

  <%# Clients %>
  <div class="nav-dropdown <%= nav_active?("clients") %>">
    <button type="button" class="nav-link nav-link--dropdown nav-dropdown__toggle" id="navClients" data-nav-dropdown aria-expanded="false" title="360° client portfolio and history">
      <%= flowbite_icon("users-group-outline") %> Clients
    </button>
    <ul class="dropdown-menu dropdown-menu-end nav-dropdown__menu" aria-labelledby="navClients">
      <li><%= link_to admin_customers_path, class: "dropdown-item #{'active' if request.path == admin_customers_path}", data: { turbo_frame: "_top" } do %><%= flowbite_icon("users-outline", class: "dropdown-item-icon") %> Client Directory<% end %></li>
      <li><%= link_to clients_corporate_accounts_path, class: "dropdown-item #{'active' if request.path.start_with?('/clients/corporate')}", data: { turbo_frame: "_top", turbo_visit_control: "reload" } do %><%= flowbite_icon("building-outline", class: "dropdown-item-icon") %> Corporate Accounts<% end %></li>
      <li><%= link_to clients_analysis_path, class: "dropdown-item #{'active' if request.path.start_with?('/clients/analysis')}" do %><%= flowbite_icon("chart-pie-outline", class: "dropdown-item-icon") %> Client Analysis<% end %></li>
    </ul>
  </div>

  <%= render "shared/nav_financials_dropdown" %>

  <%# Budget — Overview, Staff, Set up only %>
  <div class="nav-dropdown <%= nav_active?("budget") %>">
    <button type="button" class="nav-link nav-link--dropdown nav-dropdown__toggle" id="navBudget" data-nav-dropdown aria-expanded="false" aria-controls="navBudgetMenu" title="Budget overview, staff, setup">
      <%= flowbite_icon("wallet-outline") %> Budget
    </button>
    <ul class="dropdown-menu dropdown-menu-end nav-dropdown__menu" id="navBudgetMenu" aria-labelledby="navBudget" role="menu">
      <li role="none"><%= link_to budget_overview_path, class: "dropdown-item #{'active' if request.path.start_with?('/budget/overview')}", role: "menuitem" do %><%= flowbite_icon("chart-pie-outline", class: "dropdown-item-icon") %> Budget Overview<% end %></li>
      <li role="none"><%= link_to budget_staff_path, class: "dropdown-item #{'active' if request.path == budget_staff_path || request.path.start_with?('/budget/staff/')}", role: "menuitem" do %><%= flowbite_icon("users-outline", class: "dropdown-item-icon") %> Staff Management<% end %></li>
      <li role="none"><%= link_to budget_setup_path, class: "dropdown-item #{'active' if request.path == budget_setup_path}", role: "menuitem" do %><%= flowbite_icon("cog-outline", class: "dropdown-item-icon") %> Budget Set up<% end %></li>
    </ul>
  </div>

  <%# Strategy %>
  <div class="nav-dropdown <%= nav_active?("strategy") %>">
    <button type="button" class="nav-link nav-link--dropdown nav-dropdown__toggle" id="navStrategy" data-nav-dropdown aria-expanded="false" title="Campaigns, promotions and growth optimization">
      <%= flowbite_icon("tag-outline") %> Strategy
    </button>
    <ul class="dropdown-menu dropdown-menu-end nav-dropdown__menu" aria-labelledby="navStrategy">
      <li><%= link_to admin_settings_path, class: "dropdown-item" do %><%= flowbite_icon("tag-outline", class: "dropdown-item-icon") %> Promotions<% end %></li>
      <li><%= link_to admin_settings_path, class: "dropdown-item" do %><%= flowbite_icon("chart-outline", class: "dropdown-item-icon") %> Promotion Performance<% end %></li>
      <li><%= link_to insights_strategy_path, class: "dropdown-item #{'active' if request.path == insights_strategy_path}" do %><%= flowbite_icon("chart-pie-outline", class: "dropdown-item-icon") %> Strategy Insights<% end %></li>
      <li><%= link_to admin_dashboard_index_path, class: "dropdown-item" do %><%= flowbite_icon("lightbulb-outline", class: "dropdown-item-icon") %> Opportunities<% end %></li>
    </ul>
  </div>

  <%= link_to admin_settings_path, class: "nav-link #{nav_active?("settings")}", title: "Promotion & system settings" do %>
    <%= flowbite_icon("cog-outline") %> Settings
  <% end %>
</div>
