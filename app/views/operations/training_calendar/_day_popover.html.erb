<%
  events = local_assigns[:events] || instance_variable_defined?(:@events) ? @events : []
  date = local_assigns[:date] || (instance_variable_defined?(:@date) ? @date : Date.current)
%>
<%= turbo_frame_tag "tc_day_popover" do %>
  <div class="tc-day-popover" role="dialog" aria-label="Classes on <%= date.strftime('%B %d') %>">
    <h3 class="tc-day-popover__title"><%= date.strftime("%A, %b %d") %></h3>
    <ul class="tc-day-popover__list">
      <% events.each do |ev| %>
        <li><%= link_to ev.title, admin_class_workspace_path(ev), class: "tc-day-popover__link", data: { turbo_frame: "_top" } %></li>
      <% end %>
    </ul>
  </div>
<% end %>
