<%
  event = local_assigns[:event]
  tooltip = tc_event_tooltip(event)
  cancelled = event.status_label == "Cancelled"
  card_class = "tc-month-card"
  if event.respond_to?(:class_status) && event.class_status.present?
    card_class += " tc-month-card--#{event.class_status}"
  else
    card_class += " tc-month-card--public" if event.respond_to?(:public_enabled?) && event.public_enabled?
    card_class += " tc-month-card--private" if event.respond_to?(:public_enabled?) && !event.public_enabled?
  end
  card_class += " tc-month-card--cancelled" if cancelled
  max_seats = event.max_attendees.to_i
  registered = event.total_registered_seats
  fill_pct = max_seats.positive? ? (event.fill_rate_percent || 0) : 0
  is_full = max_seats.positive? && fill_pct >= 100
  fill_class = max_seats.positive? ? "tc-month-card__fill--#{fill_pct <= 25 ? 'r0-25' : (fill_pct <= 60 ? 'r25-60' : (fill_pct <= 85 ? 'r60-85' : 'r85-100'))}" : ""
  url = operations_training_calendar_event_modal_path(event)
%>
<%= link_to url, class: card_class, title: tooltip, data: { turbo_frame: "tc_event_modal" } do %>
  <span class="tc-month-card__strip" aria-hidden="true"></span>
  <span class="tc-month-card__body">
    <span class="tc-month-card__title" title="<%= event.title %>"><%= truncate(event.title, length: 22) %></span>
    <% if event.instructor.present? %><span class="tc-month-card__meta"><%= truncate(event.instructor, length: 18) %></span><% end %>
    <% if max_seats.positive? %>
      <span class="tc-month-card__progress">
        <span class="tc-month-card__seats"><%= registered %>/<%= max_seats %></span>
        <span class="tc-month-card__fill-track" role="presentation">
          <span class="tc-month-card__fill-bar <%= fill_class %>" style="width: <%= [fill_pct, 100].min %>%;"></span>
        </span>
        <% if is_full %><span class="tc-month-card__badge tc-month-card__badge--full">FULL</span><% end %>
      </span>
    <% end %>
  </span>
<% end %>
