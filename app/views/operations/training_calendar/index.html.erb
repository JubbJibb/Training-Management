<% content_for :title, "Training Calendar" %>
<div class="tc-page" data-controller="training-calendar drawer" data-drawer-mobile-modal-value="true">
  <%= render "components/odt/page_header", title: "Training Calendar", subtitle: "View and manage classes by month, week or agenda", icon: "calendar-event" do %>
    <%= link_to new_admin_training_class_path, class: "odt-btn odt-btn--primary odt-btn--md" do %>
      <i class="bi bi-plus-circle odt-btn__icon odt-btn__icon--left" aria-hidden="true"></i>
      <span class="odt-btn__label">New Training Class</span>
    <% end %>
  <% end %>

  <turbo-frame id="tc_kpis">
    <%= render "operations/training_calendar/kpis", kpi_classes: @kpi_classes, kpi_seats_sold: @kpi_seats_sold, kpi_revenue: @kpi_revenue, kpi_utilization: @kpi_utilization, kpi_nearly_full: @kpi_nearly_full %>
  </turbo-frame>

  <div class="tc-chips" id="tc_filter_chips">
    <%= render "operations/training_calendar/filter_chips", filters: @filters %>
  </div>

  <div class="tc-body tc-body--with-upcoming">
    <div class="tc-upcoming-col">
      <%= render "operations/training_calendar/upcoming_events", events: @events %>
    </div>
    <div class="tc-main">
      <div class="tc-calendar-card">
        <%= render "operations/training_calendar/calendar_toolbar", view: @view, filters: @filters, month_start: @month_start, month_end: @month_end, week_start: @week_start, week_end: @week_end %>
        <turbo-frame id="tc_calendar" data-controller="tc-calendar" data-tc-calendar-target="grid" data-action="click->tc-calendar#onGridClick">
          <%= render "operations/training_calendar/calendar", view: @view, range: @range, events: @events, events_by_date: @events_by_date, week_start: @week_start, week_end: @week_end, month_start: @month_start, month_end: @month_end, filters: @filters %>
        </turbo-frame>
      </div>
    </div>
  </div>
</div>

<%= render "operations/training_calendar/filters_drawer", filters: @filters, instructor_options: @instructor_options, location_options: @location_options %>

<turbo-frame id="tc_day_popover" class="tc-day-popover-frame"></turbo-frame>
<div id="quick_add_anchor" class="tc-quick-add-anchor" data-training-calendar-target="quickAddAnchor" hidden></div>
